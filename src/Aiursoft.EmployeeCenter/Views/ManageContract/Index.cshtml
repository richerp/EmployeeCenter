@using Aiursoft.EmployeeCenter.Services.FileStorage
@using Aiursoft.EmployeeCenter.Authorization
@using Microsoft.AspNetCore.Authorization
@model Aiursoft.EmployeeCenter.Models.ContractViewModels.ManageViewModel
@inject StorageService StorageService
@inject IAuthorizationService AuthorizationService

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Manage Contracts"]</h3>
    </div>

    <div class="col-auto ms-auto mt-n1">
        @if ((await AuthorizationService.AuthorizeAsync(User, AppPermissionNames.CanCreateContract)).Succeeded)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="align-middle" data-lucide="plus-circle"></i> @Localizer["Create new contract"]
            </a>
        }
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title">@Localizer["All Contracts"]</h5>
        <h6 class="card-subtitle text-muted">@Localizer["A list of all contract records in the system."]</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
            <tr>
                <th>@Localizer["User"]</th>
                <th>@Localizer["Name"]</th>
                <th>@Localizer["Status"]</th>
                <th>@Localizer["Created Time"]</th>
                <th class="text-end">@Localizer["Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Contracts)
            {
                <tr>
                    <td>
                        <img src="@StorageService.RelativePathToInternetUrl(item.User?.AvatarRelativePath ?? Aiursoft.EmployeeCenter.Entities.User.DefaultAvatarPath)?w=72&square=true" alt="@item.User?.DisplayName" class="rounded-circle" width="36" height="36" />
                        <span class="ms-2">@item.User?.DisplayName</span>
                    </td>
                    <td>@item.Name</td>
                    <td>
                        @switch (item.Status)
                        {
                            case Aiursoft.EmployeeCenter.Entities.ContractStatus.PendingSignature:
                                <span class="badge bg-warning">@Localizer["Pending Signature"]</span>
                                break;
                            case Aiursoft.EmployeeCenter.Entities.ContractStatus.Active:
                                <span class="badge bg-success">@Localizer["Active"]</span>
                                break;
                            case Aiursoft.EmployeeCenter.Entities.ContractStatus.Invalid:
                                <span class="badge bg-danger">@Localizer["Invalid"]</span>
                                break;
                        }
                    </td>
                    <td>@item.CreateTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <a href="@StorageService.RelativePathToInternetUrl(item.FilePath)" class="btn btn-sm btn-outline-info" target="_blank">
                            <i class="align-middle" data-lucide="download"></i> @Localizer["Download"]
                        </a>
                        @if ((await AuthorizationService.AuthorizeAsync(User, AppPermissionNames.CanCreateContract)).Succeeded)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="align-middle" data-lucide="edit-2"></i> @Localizer["Edit"]
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('@Localizer["Are you sure you want to delete this contract?"]');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="align-middle" data-lucide="trash-2"></i> @Localizer["Delete"]
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
