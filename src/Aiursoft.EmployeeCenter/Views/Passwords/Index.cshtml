@using Aiursoft.EmployeeCenter.Authorization
@using Microsoft.AspNetCore.Authorization
@model Aiursoft.EmployeeCenter.Models.PasswordsViewModels.IndexViewModel
@inject IAuthorizationService AuthorizationService

<div class="row mb-3">
    <div class="col-12">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h3>@Localizer["Passwords Management"]</h3>
                <p class="text-muted">@Localizer["Manage and view shared account passwords."]</p>
            </div>
            @if ((await AuthorizationService.AuthorizeAsync(User, AppPermissionNames.CanAddGlobalPassword)).Succeeded)
            {
                <div>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="align-middle" data-lucide="plus"></i> @Localizer["Create New"]
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 col-xl-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["My Passwords"]</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                    <tr>
                        <th>@Localizer["Title"]</th>
                        <th>@Localizer["Account"]</th>
                        <th class="text-end">@Localizer["Actions"]</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (!Model.MyPasswords.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">@Localizer["No passwords created yet."]</td>
                        </tr>
                    }
                    @foreach (var item in Model.MyPasswords)
                    {
                        <tr>
                            <td><strong>@item.Title</strong></td>
                            <td>@item.Account</td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="@Localizer["Details"]">
                                        <i class="align-middle" data-lucide="eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="@Localizer["Edit"]">
                                        <i class="align-middle" data-lucide="edit-2"></i>
                                    </a>
                                    <a asp-action="ManageShares" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="@Localizer["Manage Shares"]">
                                        <i class="align-middle" data-lucide="share-2"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Shared with Me"]</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                    <tr>
                        <th>@Localizer["Title"]</th>
                        <th>@Localizer["Owner"]</th>
                        <th>@Localizer["Permission"]</th>
                        <th class="text-end">@Localizer["Actions"]</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (!Model.SharedWithMe.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">@Localizer["No passwords shared with you."]</td>
                        </tr>
                    }
                    @foreach (var share in Model.SharedWithMe)
                    {
                        <tr>
                            <td><strong>@share.Password.Title</strong></td>
                            <td>@share.Password.Creator?.DisplayName</td>
                            <td>
                                @if (share.Permission == Aiursoft.EmployeeCenter.Entities.SharePermission.Editable)
                                {
                                    <span class="badge bg-success">@Localizer["Editable"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@Localizer["Read Only"]</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@share.PasswordId" class="btn btn-sm btn-outline-primary" title="@Localizer["Details"]">
                                        <i class="align-middle" data-lucide="eye"></i>
                                    </a>
                                    @if (share.Permission == Aiursoft.EmployeeCenter.Entities.SharePermission.Editable)
                                    {
                                        <a asp-action="Edit" asp-route-id="@share.PasswordId" class="btn btn-sm btn-outline-secondary" title="@Localizer["Edit"]">
                                            <i class="align-middle" data-lucide="edit-2"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
