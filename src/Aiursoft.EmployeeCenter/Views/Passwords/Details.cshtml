@using Aiursoft.EmployeeCenter.Authorization
@using Microsoft.AspNetCore.Authorization
@model Aiursoft.EmployeeCenter.Models.PasswordsViewModels.DetailsViewModel
@inject IAuthorizationService AuthorizationService

<div class="row mb-3">
    <div class="col-12">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h3>@Localizer["Password Details"]</h3>
                <p class="text-muted">@Model.Password.Title</p>
            </div>
            <div class="btn-group">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="align-middle" data-lucide="arrow-left"></i> @Localizer["Back"]
                </a>
                @if (Model.Permission == Aiursoft.EmployeeCenter.Entities.SharePermission.Editable)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Password.Id" class="btn btn-outline-primary">
                        <i class="align-middle" data-lucide="edit-2"></i> @Localizer["Edit"]
                    </a>
                }
                @{
                    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                    var isOwner = Model.Password.CreatorId == userId;
                    var canManageAny = (await AuthorizationService.AuthorizeAsync(User, AppPermissionNames.CanManageAnyPassword)).Succeeded;
                }
                @if (isOwner || canManageAny)
                {
                    <a asp-action="ManageShares" asp-route-id="@Model.Password.Id" class="btn btn-outline-info">
                        <i class="align-middle" data-lucide="share-2"></i> @Localizer["Manage Shares"]
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.Password.Id" method="post" class="d-inline" onsubmit="return confirm('@Localizer["Are you sure you want to delete this password?"]')">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="align-middle" data-lucide="trash-2"></i> @Localizer["Delete"]
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 col-lg-6">
        <div class="card">
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label text-muted">@Localizer["Account / Username"]</label>
                    <div class="input-group">
                        <input type="text" class="form-control" value="@Model.Password.Account" readonly id="account-input" />
                        <button class="btn btn-outline-secondary copy-btn" type="button" data-target="account-input">
                            <i class="align-middle" data-lucide="copy"></i>
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted">@Localizer["Password / Secret"]</label>
                    <div class="input-group">
                        <input type="password" class="form-control" value="@Model.Password.Secret" readonly id="secret-input" />
                        <button class="btn btn-outline-secondary" type="button" onclick="var input = document.getElementById('secret-input'); if(input.type === 'password') { input.type = 'text'; this.innerHTML = '<i class=\'align-middle\' data-lucide=\'eye-off\'></i>'; lucide.createIcons(); } else { input.type = 'password'; this.innerHTML = '<i class=\'align-middle\' data-lucide=\'eye\'></i>'; lucide.createIcons(); }">
                            <i class="align-middle" data-lucide="eye"></i>
                        </button>
                        <button class="btn btn-outline-secondary copy-btn" type="button" data-target="secret-input">
                            <i class="align-middle" data-lucide="copy"></i>
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted">@Localizer["Note"]</label>
                    <div class="p-3 bg-light rounded" style="white-space: pre-wrap;">@(string.IsNullOrWhiteSpace(Model.Password.Note) ? Localizer["No notes."] : Model.Password.Note)</div>
                </div>
                <hr />
                <div class="small text-muted">
                    <p class="mb-1">@Localizer["Created by"]: @Model.Password.Creator?.DisplayName</p>
                    <p class="mb-0">@Localizer["Created on"]: @Model.Password.CreationTime.ToString("yyyy-MM-dd HH:mm")</p>
                </div>
            </div>
        </div>
    </div>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const copyBtns = document.querySelectorAll('.copy-btn');
            copyBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    const targetId = this.dataset.target;
                    const input = document.getElementById(targetId);
                    
                    // Temp change type to text to copy if it's password
                    const originalType = input.type;
                    input.type = 'text';
                    input.select();
                    document.execCommand('copy');
                    input.type = originalType;
                    
                    const originalHTML = this.innerHTML;
                    this.innerHTML = '<i class="align-middle" data-lucide="check"></i>';
                    lucide.createIcons();
                    setTimeout(() => {
                        this.innerHTML = originalHTML;
                        lucide.createIcons();
                    }, 2000);
                });
            });
        });
    </script>
}
