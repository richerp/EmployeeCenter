@model Aiursoft.EmployeeCenter.Models.ServicesViewModels.ManageDnsProvidersViewModel

<h1 class="h3 mb-3">@Localizer["DNS Providers"]</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Existing DNS Providers"]</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@Localizer["Name"]</th>
                            <th>@Localizer["Description"]</th>
                            <th class="text-end">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.DnsProviders)
                        {
                            <tr>
                                <td>@p.Name</td>
                                <td>@p.Description</td>
                                <td class="text-end">
                                    <form asp-action="DeleteDnsProvider" asp-route-id="@p.Id" method="post" onsubmit="return confirm(getLocalizedText('confirm-are-you-sure', '@Localizer["Are you sure?"]'));">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="align-middle" data-lucide="trash-2"></i> @Localizer["Delete"]
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Add New DNS Provider"]</h5>
            </div>
            <div class="card-body">
                <form asp-action="CreateDnsProvider">
                    <div class="mb-3">
                        <label asp-for="NewName" class="form-label"></label>
                        <input asp-for="NewName" class="form-control" required placeholder="@Localizer["e.g. Cloudflare"]" />
                        <span asp-validation-for="NewName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewDescription" class="form-label"></label>
                        <input asp-for="NewDescription" class="form-control" placeholder="@Localizer["e.g. Global CDN & DNS"]" />
                        <span asp-validation-for="NewDescription" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">@Localizer["Add Provider"]</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-light">@Localizer["Back to Services"]</a>
</div>

<div id="loc-data" hidden>
    <span data-key="confirm-are-you-sure">@Localizer["Are you sure?"]</span>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <partial name="_LocalizationHelper" />
}
