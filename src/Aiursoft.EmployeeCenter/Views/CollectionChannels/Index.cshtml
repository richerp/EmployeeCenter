@model Aiursoft.EmployeeCenter.Models.CollectionChannelsViewModels.IndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Collection Channels"]</h3>
    </div>

    <div class="col-auto ms-auto mt-n1">
        <a asp-action="Create" class="btn btn-primary">
            <i class="align-middle" data-lucide="plus-circle"></i> @Localizer["Add new channel"]
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title">@Localizer["All Collection Channels"]</h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
            <tr>
                <th>@Localizer["Payer"]</th>
                <th>@Localizer["Payee"]</th>
                <th>@Localizer["Amount"]</th>
                <th>@Localizer["Method"]</th>
                <th>@Localizer["Recurring"]</th>
                <th>@Localizer["Status"]</th>
                <th class="text-end">@Localizer["Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Channels)
            {
                <tr>
                    <td>@(item.Payer?.CompanyName ?? Localizer["N/A"].Value)</td>
                    <td>@(item.Payee?.CompanyName ?? Localizer["N/A"].Value)</td>
                    <td>@item.ReferenceAmount @item.Currency</td>
                    <td>@item.PaymentMethod</td>
                    <td>
                        @if (item.IsRecurring)
                        {
                            <span class="badge bg-info">@item.RecurringPeriod</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Localizer["One-time"]</span>
                        }
                    </td>
                    <td>
                        @switch (item.Status)
                        {
                            case CollectionChannelStatus.Active:
                                <span class="badge bg-success">@Localizer["Active"]</span>
                                break;
                            case CollectionChannelStatus.Paused:
                                <span class="badge bg-warning">@Localizer["Paused"]</span>
                                break;
                            case CollectionChannelStatus.Terminated:
                                <span class="badge bg-danger">@Localizer["Terminated"]</span>
                                break;
                        }
                    </td>
                    <td class="text-end">
                        <div class="btn-group">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="@Localizer["Details"]">
                                <i class="align-middle" data-lucide="eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="@Localizer["Edit"]">
                                <i class="align-middle" data-lucide="edit"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
