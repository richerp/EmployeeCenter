@model Aiursoft.EmployeeCenter.Models.LeaveViewModels.IndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["My Leave Balance"]</h3>
    </div>
</div>

<div class="row">
    <div class="col-12 col-xl-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Leave Balance Summary"]</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <i class="align-middle text-primary" data-lucide="calendar" style="width: 48px; height: 48px;"></i>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h3 class="mb-0">@Model.RemainingAnnualLeave.ToString("0.##")</h3>
                                <p class="text-muted mb-0">@Localizer["Remaining Annual Leave Days"]</p>
                                <small class="text-muted">
                                    @Localizer["Allocation"]: @Model.AnnualLeaveAllocation.ToString("0.##") @Localizer["days"]
                                    @if (Model.CarriedOverAnnualLeave > 0)
                                    {
                                        <text><br/>@Localizer["Carried Over"]: @Model.CarriedOverAnnualLeave.ToString("0.##") @Localizer["days"]</text>
                                    }
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <i class="align-middle text-success" data-lucide="heart-pulse" style="width: 48px; height: 48px;"></i>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h3 class="mb-0">@Model.RemainingSickLeave.ToString("0.##")</h3>
                                <p class="text-muted mb-0">@Localizer["Remaining Sick Leave Days"]</p>
                                <small class="text-muted">
                                    @Localizer["Allocation"]: @Model.SickLeaveAllocation.ToString("0.##") @Localizer["days"]
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
                @if (Model.CanApplyLeave)
                {
                            <div class="mt-3">
                                <a asp-action="Apply" class="btn btn-primary">
                                    <i class="align-middle" data-lucide="plus-circle"></i>
                            @Localizer["Apply for Leave"]
                                </a>
                            </div>
                }
                else
                {
                            <div class="alert alert-warning mt-3" role="alert">
                                <i class="align-middle" data-lucide="alert-triangle"></i>
                        @Localizer["You have no remaining leave days to apply."]
                            </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Leave Policy"]</h5>
            </div>
            <div class="card-body">
                <h6>@Localizer["Annual Leave"]</h6>
                <ul class="mb-3">
                    <li>@Localizer["12 days per year, granted on January 1st"]</li>
                    <li>@Localizer["Unused annual leave can carry over to the next year"]</li>
                    <li>@Localizer["Cannot carry over to the third year"]</li>
                    <li>@Localizer["Requires approval before use"]</li>
                </ul>

                <h6>@Localizer["Sick Leave"]</h6>
                <ul class="mb-0">
                    <li>@Localizer["7 days per year"]</li>
                    <li>@Localizer["Does not carry over to the next year"]</li>
                    <li>@Localizer["No approval required, but must submit supporting documents after leave"]</li>
                    <li>@Localizer["Physical illness: Hospital diagnosis required"]</li>
                    <li>@Localizer["Mental health: No diagnosis required"]</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">@Localizer["Leave History"]</h5>
                <h6 class="card-subtitle text-muted">@Localizer["All your leave applications, including pending and historical records."]</h6>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                    <tr>
                        <th>@Localizer["Leave Type"]</th>
                        <th>@Localizer["Start Date"]</th>
                        <th>@Localizer["End Date"]</th>
                        <th>@Localizer["Total Days"]</th>
                        <th>@Localizer["Status"]</th>
                        <th>@Localizer["Submitted At"]</th>
                        <th>@Localizer["Actions"]</th>
                    </tr>
                    </thead>
                    <tbody>
                        @if (Model.LeaveHistory.Count == 0)
                        {
                                <tr>
                                    <td colspan="7" class="text-center text-muted">
                                    @Localizer["No leave applications yet."]
                                    </td>
                                </tr>
                        }
                        else
                        {
                            foreach (var item in Model.LeaveHistory)
                            {
                                            <tr>
                                                <td>
                                        @if (item.LeaveType == Aiursoft.EmployeeCenter.Entities.LeaveType.AnnualLeave)
                                        {
                                                                <span class="badge bg-primary">@Localizer["Annual Leave"]</span>
                                        }
                                        else
                                        {
                                                                <span class="badge bg-success">@Localizer["Sick Leave"]</span>
                                        }
                                                </td>
                                                <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                                                <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                                                <td>@item.TotalDays.ToString("0.##") @Localizer["days"]</td>
                                                <td>
                                        @if (item.IsWithdrawn)
                                        {
                                                        <span class="badge bg-secondary">@Localizer["Withdrawn"]</span>
                                        }
                                        else if (item.IsPending)
                                        {
                                                                <span class="badge bg-warning">@Localizer["Pending Approval"]</span>
                                        }
                                        else if (item.IsApproved)
                                        {
                                                                <span class="badge bg-success">@Localizer["Approved"]</span>
                                        }
                                        else
                                        {
                                                                <span class="badge bg-danger">@Localizer["Rejected"]</span>
                                        }
                                                </td>
                                                <td>@item.SubmittedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                                <td>
                                        @if (!item.IsWithdrawn && DateTime.UtcNow.Date < item.StartDate.Date)
                                        {
                                                            <form asp-action="Withdraw" asp-route-id="@item.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('@Localizer["Are you sure you want to withdraw this leave application?"]');">
                                                                    <i class="align-middle" data-lucide="x-circle"></i> @Localizer["Withdraw"]
                                                                </button>
                                                            </form>
                                        }
                                                </td>
                                            </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
