@model Aiursoft.EmployeeCenter.Models.LeaveViewModels.IncomingViewModel
@inject Aiursoft.EmployeeCenter.Services.FileStorage.StorageService StorageService

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Approval Center"]</h3>
    </div>
</div>

<!-- Statistics Cards -->
<div class="row">
    <div class="col-lg-6 col-xl-3 d-flex">
        <div class="card flex-fill">
            <div class="card-header">
                <h5 class="card-title mb-0 mt-2">@Localizer["Pending Approvals"]</h5>
            </div>
            <div class="card-body my-0 pt-0">
                <div class="row d-flex align-items-center mb-3">
                    <div class="col-12">
                        <h3 class="d-flex align-items-center mb-0 fw-light">
                            @Model.PendingCount
                        </h3>
                        <small class="text-muted">@Localizer["awaiting your review"]</small>
                    </div>
                </div>
                <div class="progress progress-sm shadow-sm mb-1">
                    <div class="progress-bar bg-warning" role="progressbar" style="width: @(Model.PendingCount > 0 ? "100" : "0")%"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6 col-xl-3 d-flex">
        <div class="card flex-fill">
            <div class="card-header">
                <h5 class="card-title mb-0 mt-2">@Localizer["Approved This Month"]</h5>
            </div>
            <div class="card-body my-0 pt-0">
                <div class="row d-flex align-items-center mb-3">
                    <div class="col-12">
                        <h3 class="d-flex align-items-center mb-0 fw-light">
                            @Model.ApprovedThisMonth
                        </h3>
                        <small class="text-muted">@Localizer["applications approved"]</small>
                    </div>
                </div>
                <div class="progress progress-sm shadow-sm mb-1">
                    <div class="progress-bar bg-success" role="progressbar" style="width: @(Model.ApprovedThisMonth > 0 ? "100" : "0")%"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6 col-xl-3 d-flex">
        <div class="card flex-fill">
            <div class="card-header">
                <h5 class="card-title mb-0 mt-2">@Localizer["Rejected This Month"]</h5>
            </div>
            <div class="card-body my-0 pt-0">
                <div class="row d-flex align-items-center mb-3">
                    <div class="col-12">
                        <h3 class="d-flex align-items-center mb-0 fw-light">
                            @Model.RejectedThisMonth
                        </h3>
                        <small class="text-muted">@Localizer["applications rejected"]</small>
                    </div>
                </div>
                <div class="progress progress-sm shadow-sm mb-1">
                    <div class="progress-bar bg-danger" role="progressbar" style="width: @(Model.RejectedThisMonth > 0 ? "100" : "0")%"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6 col-xl-3 d-flex">
        <div class="card flex-fill">
            <div class="card-header">
                <h5 class="card-title mb-0 mt-2">@Localizer["Team on Leave"]</h5>
            </div>
            <div class="card-body my-0 pt-0">
                <div class="row d-flex align-items-center mb-3">
                    <div class="col-12">
                        <h3 class="d-flex align-items-center mb-0 fw-light">
                            @Model.TeamOnLeaveCount
                        </h3>
                        <small class="text-muted">@Localizer["currently absent"]</small>
                    </div>
                </div>
                <div class="progress progress-sm shadow-sm mb-1">
                    <div class="progress-bar bg-info" role="progressbar" style="width: @(Model.TeamOnLeaveCount > 0 ? "100" : "0")%"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Warning Alert -->
@if (Model.PendingCount > 0)
{
    <div class="row mb-3">
        <div class="col-12">
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-icon">
                    <i class="align-middle" data-lucide="alert-triangle"></i>
                </div>
                <div class="alert-message">
                    <h5 class="alert-heading mb-2">
                        @Localizer["Important: Approval Decisions Are Final"]
                    </h5>
                    <p class="mb-2">
                        @Localizer["Once you approve or reject a leave application, the decision cannot be undone. Please review carefully before taking action."]
                    </p>
                    <small class="text-muted">
                        <strong>@Localizer["If the employee wishes to cancel:"]</strong> @Localizer["They can withdraw their own application before it starts."]
                        • <strong>@Localizer["If rejected by mistake:"]</strong> @Localizer["The employee must submit a new application."]
                    </small>
                </div>
            </div>
        </div>
    </div>
}

<!-- Main Content with Tabs -->
<div class="card">
    <div class="card-header">
        <ul class="nav nav-tabs card-header-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <a class="nav-link active" data-bs-toggle="tab" href="#pending" role="tab">
                    @Localizer["Pending Approval"] 
                    @if (Model.PendingCount > 0)
                    {
                        <span class="badge bg-warning ms-1">@Model.PendingCount</span>
                    }
                </a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" data-bs-toggle="tab" href="#history" role="tab">
                    @Localizer["Approval History"]
                    @if (Model.ApprovalHistory.Count > 0)
                    {
                        <span class="badge bg-secondary ms-1">@Model.ApprovalHistory.Count</span>
                    }
                </a>
            </li>
        </ul>
    </div>
    <div class="tab-content">
        <!-- Pending Tab -->
        <div class="tab-pane fade show active" id="pending" role="tabpanel">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@Localizer["Applicant"]</th>
                            <th>@Localizer["Type"]</th>
                            <th>@Localizer["Period"]</th>
                            <th>@Localizer["Days"]</th>
                            <th>@Localizer["Reason"]</th>
                            <th>@Localizer["Submitted"]</th>
                            <th>@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.IncomingLeaves.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">@Localizer["No pending applications."]</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.IncomingLeaves)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@StorageService.RelativePathToInternetUrl(item.User.AvatarRelativePath)?w=64&square=true" class="rounded-circle me-2" alt="@item.User.DisplayName" width="32" height="32">
                                            <div>
                                                <div class="fw-bold">@item.User.DisplayName</div>
                                                <div class="small text-muted">@item.User.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (item.LeaveType == LeaveType.AnnualLeave)
                                        {
                                            <span class="badge bg-primary">@Localizer["Annual Leave"]</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">@Localizer["Sick Leave"]</span>
                                        }
                                    </td>
                                    <td>
                                        <div><label data-utc-time="@item.StartDate.ToHtmlDateTime()"></label></div>
                                        <small class="text-muted">@Localizer["to"] <label data-utc-time="@item.EndDate.ToHtmlDateTime()"></label></small>
                                    </td>
                                    <td>@item.TotalDays.ToString("0.##")</td>
                                    <td>@item.Reason</td>
                                    <td><label class="text-muted" data-utc-time="@item.SubmittedAt.ToHtmlDateTime()"></label></td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <form asp-action="Review" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="approved" value="true" />
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="align-middle" data-lucide="check"></i> @Localizer["Approve"]
                                                </button>
                                            </form>
                                            <form asp-action="Review" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="approved" value="false" />
                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    <i class="align-middle" data-lucide="x"></i> @Localizer["Reject"]
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- History Tab -->
        <div class="tab-pane fade" id="history" role="tabpanel">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@Localizer["Applicant"]</th>
                            <th>@Localizer["Type"]</th>
                            <th>@Localizer["Period"]</th>
                            <th>@Localizer["Days"]</th>
                            <th>@Localizer["Decision"]</th>
                            <th>@Localizer["Approver"]</th>
                            <th>@Localizer["Reviewed"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ApprovalHistory.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">@Localizer["No approval history."]</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.ApprovalHistory)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@StorageService.RelativePathToInternetUrl(item.User.AvatarRelativePath)?w=64&square=true" class="rounded-circle me-2" alt="@item.User.DisplayName" width="32" height="32">
                                            <div>
                                                <div class="fw-bold">@item.User.DisplayName</div>
                                                <div class="small text-muted">@item.User.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (item.LeaveType == LeaveType.AnnualLeave)
                                        {
                                            <span class="badge bg-primary">@Localizer["Annual Leave"]</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">@Localizer["Sick Leave"]</span>
                                        }
                                    </td>
                                    <td>
                                        <div><label data-utc-time="@item.StartDate.ToHtmlDateTime()"></label></div>
                                        <small class="text-muted">@Localizer["to"] <label data-utc-time="@item.EndDate.ToHtmlDateTime()"></label></small>
                                    </td>
                                    <td>@item.TotalDays.ToString("0.##")</td>
                                    <td>
                                        @if (item.IsApproved)
                                        {
                                            <span class="badge bg-success">@Localizer["Approved"]</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">@Localizer["Rejected"]</span>
                                        }
                                    </td>
                                    <td>@(item.ReviewedBy?.DisplayName ?? "-")</td>
                                    <td><label class="text-muted" data-utc-time="@item.ReviewedAt?.ToHtmlDateTime()"></label></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
