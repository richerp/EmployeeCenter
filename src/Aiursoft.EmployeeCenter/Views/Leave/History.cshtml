@model Aiursoft.EmployeeCenter.Models.LeaveViewModels.HistoryViewModel
@{
    ViewData["Title"] = Localizer["My Approval History"];
}

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["My Approval History"]</h3>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title">@Localizer["Reviewed Applications"]</h5>
        <h6 class="card-subtitle text-muted">@Localizer["History of leave applications you have reviewed."]</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>@Localizer["Applicant"]</th>
                    <th>@Localizer["Leave Type"]</th>
                    <th>@Localizer["Start Date"]</th>
                    <th>@Localizer["End Date"]</th>
                    <th>@Localizer["Total Days"]</th>
                    <th>@Localizer["Status"]</th>
                    <th>@Localizer["Reviewed At"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ApprovedLeaves.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">@Localizer["No history available."]</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.ApprovedLeaves)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="@item.User.AvatarRelativePath" class="rounded-circle me-2"
                                        alt="@item.User.DisplayName" width="32" height="32">
                                    <div>
                                        <div class="fw-bold">@item.User.DisplayName</div>
                                        <div class="small text-muted">@item.User.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (item.LeaveType == Aiursoft.EmployeeCenter.Entities.LeaveType.AnnualLeave)
                                {
                                    <span class="badge bg-primary">@Localizer["Annual Leave"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@Localizer["Sick Leave"]</span>
                                }
                            </td>
                            <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.TotalDays.ToString("0.##") @Localizer["days"]</td>
                            <td>
                                @if (item.IsApproved)
                                {
                                    <span class="badge bg-success">@Localizer["Approved"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@Localizer["Rejected"]</span>
                                }
                            </td>
                            <td>@item.ReviewedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
