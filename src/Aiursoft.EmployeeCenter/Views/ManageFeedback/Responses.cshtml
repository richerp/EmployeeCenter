@model Aiursoft.EmployeeCenter.Models.ManageFeedbackViewModels.ResponsesViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Responses for: {0}", Model.Questionnaire.Title]</h3>
    </div>
    <div class="col-auto ms-auto text-end mt-n1">
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="align-middle" data-lucide="arrow-left"></i> @Localizer["Back to Questionnaires"]
        </a>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>@Localizer["Employee"]</th>
                            <th>@Localizer["Submit Time"]</th>
                            <th class="text-end">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Responses)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Users" asp-action="Details" asp-route-id="@r.UserId" class="text-dark">
                                        @r.User.DisplayName
                                    </a>
                                </td>
                                <td>@r.SubmitTime.ToLocalTime().ToString("g")</td>
                                <td class="text-end">
                                    <a asp-action="ResponseDetail" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">@Localizer["View Details"]</a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Responses.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">@Localizer["No responses yet."]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
