@model Aiursoft.EmployeeCenter.Models.ManageFeedbackViewModels.ResponseDetailViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Response from"] <a asp-controller="Users" asp-action="Details" asp-route-id="@Model.Response.UserId" class="text-body">@Model.Response.User.DisplayName</a></h3>
    </div>
    <div class="col-auto ms-auto text-end mt-n1">
        <a asp-action="Responses" asp-route-id="@Model.Response.QuestionnaireId" class="btn btn-outline-secondary shadow-sm">
            <i class="align-middle" data-lucide="arrow-left"></i> @Localizer["Back to Responses"]
        </a>
    </div>
</div>

<div class="row">
    <div class="col-12">
        @foreach (var qr in Model.Response.QuestionResponses)
        {
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="card-title mb-0">@qr.Question.Title</h5>
                    <small class="text-muted">@qr.Question.Type</small>
                </div>
                <div class="card-body">
                    <p class="mb-0"><strong>@Localizer["Answer:"]</strong></p>
                    <p class="bg-light p-3 rounded mt-2">@qr.Answer</p>
                </div>
            </div>
        }
    </div>
</div>
