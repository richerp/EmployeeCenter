@using Aiursoft.EmployeeCenter.Entities
@model Aiursoft.EmployeeCenter.Models.ManageFeedbackViewModels.EditQuestionViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Edit Question"]</h3>
    </div>
</div>

<div class="row">
    <div class="col-12 col-xl-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="EditQuestion" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">@Localizer["Title"]</label>
                        <input asp-for="Title" class="form-control" id="question-title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                        <small class="form-text text-muted" id="title-help-text">@Localizer["For fill-in-the-blank, use [____] for blanks."]</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Type" class="form-label">@Localizer["Type"]</label>
                        <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<SignalQuestionType>()" id="question-type"></select>
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Tags" class="form-label">@Localizer["Tags"]</label>
                        <input asp-for="Tags" class="form-control" />
                        <span asp-validation-for="Tags" class="text-danger"></span>
                    </div>

                    <input type="hidden" asp-for="Meta" id="meta-input" />

                    <!-- Multiple Choice Options -->
                    <div id="multiple-choice-section" class="mb-3" style="display:none;">
                        <label class="form-label">@Localizer["Options"]</label>
                        <div id="options-container"></div>
                        <button type="button" class="btn btn-sm btn-outline-primary mt-2" id="add-option-btn">
                            <i class="align-middle" data-lucide="plus"></i> @Localizer["Add Option"]
                        </button>
                    </div>

                    <!-- Fill in the blank Helper -->
                    <div id="fill-in-blank-section" class="mb-3" style="display:none;">
                         <button type="button" class="btn btn-sm btn-outline-primary mt-2" id="add-blank-btn">
                            <i class="align-middle" data-lucide="plus"></i> @Localizer["Insert Blank"]
                        </button>
                    </div>

                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary">@Localizer["Save Changes"]</button>
                        <a asp-action="Questions" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const typeSelect = document.getElementById('question-type');
        const metaInput = document.getElementById('meta-input');
        const multipleChoiceSection = document.getElementById('multiple-choice-section');
        const fillInBlankSection = document.getElementById('fill-in-blank-section');
        const optionsContainer = document.getElementById('options-container');
        const addOptionBtn = document.getElementById('add-option-btn');
        const addBlankBtn = document.getElementById('add-blank-btn');
        const titleInput = document.getElementById('question-title');

        let options = [];

        // Try to parse existing meta
        try {
            if (metaInput.value) {
                const parsed = JSON.parse(metaInput.value);
                if (parsed.Options && Array.isArray(parsed.Options)) {
                    options = parsed.Options;
                }
            }
        } catch (e) {
            console.error("Failed to parse meta", e);
        }

        if (options.length === 0) {
            options = ['', '']; // Default 2 options
        }

        function renderOptions() {
            optionsContainer.innerHTML = '';
            options.forEach((opt, index) => {
                const row = document.createElement('div');
                row.className = 'input-group mb-2';
                
                const input = document.createElement('input');
                input.type = 'text';
                input.className = 'form-control';
                input.value = opt;
                input.placeholder = `Option ${index + 1}`;
                input.oninput = (e) => {
                    options[index] = e.target.value;
                    updateMeta();
                };

                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'btn btn-outline-danger';
                removeBtn.textContent = 'Remove';
                removeBtn.onclick = () => {
                    options.splice(index, 1);
                    renderOptions();
                    updateMeta();
                };

                row.appendChild(input);
                row.appendChild(removeBtn);
                optionsContainer.appendChild(row);
            });
            updateMeta();
        }

        function updateMeta() {
            if (typeSelect.value === '0') { // MultipleChoice
                metaInput.value = JSON.stringify({ Options: options });
            } else {
                metaInput.value = '';
            }
        }

        function toggleSections() {
            const val = typeSelect.value;
            if (val === '0') { // MultipleChoice
                multipleChoiceSection.style.display = 'block';
                fillInBlankSection.style.display = 'none';
                updateMeta(); 
            } else if (val === '1') { // FillInTheBlank
                multipleChoiceSection.style.display = 'none';
                fillInBlankSection.style.display = 'block';
                metaInput.value = '';
            } else {
                multipleChoiceSection.style.display = 'none';
                fillInBlankSection.style.display = 'none';
                metaInput.value = '';
            }
        }

        addOptionBtn.onclick = () => {
            options.push('');
            renderOptions();
        };

        addBlankBtn.onclick = () => {
            const cursorStart = titleInput.selectionStart;
            const cursorEnd = titleInput.selectionEnd;
            const text = titleInput.value;
            const before = text.substring(0, cursorStart);
            const after = text.substring(cursorEnd);
            titleInput.value = before + '[____]' + after;
            titleInput.focus();
            titleInput.selectionStart = titleInput.selectionEnd = cursorStart + 6;
        };

        typeSelect.onchange = toggleSections;

        renderOptions();
        toggleSections();
    });
</script>
