@model Aiursoft.EmployeeCenter.Models.ManageFeedbackViewModels.IndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Manage Feedback"]</h3>
    </div>
    <div class="col-auto ms-auto text-end mt-n1">
        <a asp-action="Questions" class="btn btn-outline-primary shadow-sm me-2">
            <i class="align-middle" data-lucide="help-circle"></i> @Localizer["Manage Questions"]
        </a>
        <a asp-action="CreateQuestionnaire" class="btn btn-primary shadow-sm">
            <i class="align-middle" data-lucide="plus"></i> @Localizer["Create Questionnaire"]
        </a>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Questionnaires"]</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>@Localizer["Title"]</th>
                            <th>@Localizer["Questions"]</th>
                            <th>@Localizer["Responses"]</th>
                            <th>@Localizer["Status"]</th>
                            <th>@Localizer["Created"]</th>
                            <th class="text-end">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var q in Model.Questionnaires)
                        {
                            <tr>
                                <td>@q.Title</td>
                                <td>@q.Questions.Count()</td>
                                <td>
                                    <a asp-action="Responses" asp-route-id="@q.Id">
                                        @q.Responses.Count()
                                    </a>
                                </td>
                                <td>
                                    @if (q.IsActive)
                                    {
                                        <span class="badge bg-success">@Localizer["Active"]</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@Localizer["Inactive"]</span>
                                    }
                                </td>
                                <td>@q.CreationTime.ToLocalTime().ToString("g")</td>
                                <td class="text-end">
                                    <a asp-action="EditQuestionnaire" asp-route-id="@q.Id" class="btn btn-sm btn-outline-primary me-1">@Localizer["Edit"]</a>
                                    <form asp-action="DeleteQuestionnaire" asp-route-id="@q.Id" method="post" class="d-inline" onsubmit="return confirm(getLocalizedText('confirm-are-you-sure', '@Localizer["Are you sure?"]'));">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@Localizer["Delete"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!Model.Questionnaires.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">@Localizer["No questionnaires created yet."]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="loc-data" hidden>
    <span data-key="confirm-are-you-sure">@Localizer["Are you sure?"]</span>
</div>

@section scripts {
    <partial name="_LocalizationHelper" />
}
