@model Aiursoft.EmployeeCenter.Models.LedgerViewModels.CreateAccountViewModel
@using Aiursoft.EmployeeCenter.Entities
@{
    ViewData["Title"] = Localizer["Create New Account"];
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">@Localizer["Create New Account"]</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <form asp-action="CreateAccount" method="post">
                <input type="hidden" asp-for="EntityId" />
                <div class="form-group">
                    <label asp-for="AccountName">@Localizer["Account Name"]</label>
                    <input asp-for="AccountName" class="form-control" placeholder="e.g. Statrys Checking" />
                    <span asp-validation-for="AccountName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="AccountType">@Localizer["Account Type"]</label>
                    <select asp-for="AccountType" class="form-control" asp-items="Html.GetEnumSelectList<FinanceAccountType>()"></select>
                    <span asp-validation-for="AccountType" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Currency">@Localizer["Currency"]</label>
                    <input asp-for="Currency" class="form-control" placeholder="e.g. HKD, CNY" />
                    <span asp-validation-for="Currency" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">@Localizer["Create"]</button>
                <a asp-action="Accounts" asp-route-id="@Model.EntityId" class="btn btn-secondary">@Localizer["Cancel"]</a>
            </form>
        </div>
    </div>
</div>
