@model Aiursoft.EmployeeCenter.Models.LedgerViewModels.DashboardViewModel
@inject Aiursoft.EmployeeCenter.Services.FileStorage.StorageService StorageService
@{
    ViewData["Title"] = Model.Entity.CompanyName + " - " + (Model.FilteredAccount != null ? Model.FilteredAccount.AccountName : Localizer["Ledger Dashboard"]);
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        @if (Model.FilteredAccount != null)
        {
            <h1 class="h3 mb-0 text-gray-800">
                <a asp-action="Dashboard" asp-route-id="@Model.Entity.Id" class="text-decoration-none text-gray-800">
                    <i class="fas fa-chevron-left fa-sm mr-2"></i>
                </a>
                @Model.FilteredAccount.AccountName - @Localizer["Dashboard"]
            </h1>
        }
        else
        {
            <h1 class="h3 mb-0 text-gray-800">@Model.Entity.CompanyName - @Localizer["Dashboard"]</h1>
        }
        <div>
            <a asp-controller="Ledger" asp-action="Accounts" asp-route-id="@Model.Entity.Id" class="btn btn-sm btn-info shadow-sm">
                <i class="fas fa-list fa-sm text-white-50"></i> @Localizer["Manage Accounts"]
            </a>
            <a asp-controller="Ledger" asp-action="CreateTransaction" asp-route-id="@Model.Entity.Id" class="btn btn-sm btn-primary shadow-sm">
                <i class="fas fa-plus fa-sm text-white-50"></i> @Localizer["New Transaction"]
            </a>
        </div>
    </div>

    @if (Model.FilteredAccount != null)
    {
        <div class="row">
            <div class="col-xl-3 col-md-6 mb-4">
                @{
                    var colorClass = "primary";
                    var iconClass = "fa-coins";
                    if (Model.FilteredAccount.AccountType == FinanceAccountType.Asset)
                    {
                        colorClass = "success";
                        iconClass = "fa-wallet";
                    }
                    else if (Model.FilteredAccount.AccountType == FinanceAccountType.Liability)
                    {
                        colorClass = "danger";
                        iconClass = "fa-hand-holding-usd";
                    }
                    else if (Model.FilteredAccount.AccountType == FinanceAccountType.Expense)
                    {
                        colorClass = "warning";
                        iconClass = "fa-shopping-cart";
                    }
                    else if (Model.FilteredAccount.AccountType == FinanceAccountType.Income)
                    {
                        colorClass = "info";
                        iconClass = "fa-receipt";
                    }
                }
                <div class="card border-left-@colorClass shadow h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-@colorClass text-uppercase mb-1">
                                    @Model.FilteredAccount.AccountName (@Model.FilteredAccount.Currency)
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">
                                    @Model.FilteredAccountBalance.ToString("N2")
                                </div>
                            </div>
                            <div class="col-auto">
                                <i class="fas @iconClass fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.FilteredAccount == null)
    {
        <!-- Content Row -->
        <div class="row">
            <!-- Asset Snapshots -->
            @foreach (var ab in Model.Accounts.Where(a => a.Account.AccountType == FinanceAccountType.Asset))
            {
                <div class="col-xl-3 col-md-6 mb-4">
                    <a asp-action="Dashboard" asp-route-id="@Model.Entity.Id" asp-route-accountId="@ab.Account.Id" class="text-decoration-none">
                        <div class="card border-left-success shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                            @ab.Account.AccountName (@ab.Account.Currency)
                                        </div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                                            @ab.Balance.ToString("N2")
                                        </div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="fas fa-wallet fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }

            <!-- Liability Snapshots -->
            @foreach (var ab in Model.Accounts.Where(a => a.Account.AccountType == FinanceAccountType.Liability))
            {
                <div class="col-xl-3 col-md-6 mb-4">
                    <a asp-action="Dashboard" asp-route-id="@Model.Entity.Id" asp-route-accountId="@ab.Account.Id" class="text-decoration-none">
                        <div class="card border-left-danger shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                            @ab.Account.AccountName (@ab.Account.Currency)
                                        </div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                                            @ab.Balance.ToString("N2")
                                        </div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="fas fa-hand-holding-usd fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }

    <div class="row">
        <!-- Transaction Feed -->
        <div class="col-xl-8 col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">
                        @(Model.FilteredAccount != null ? Localizer["Account Transactions"] : Localizer["Recent Transactions"])
                    </h6>
                    @if (Model.FilteredAccount == null)
                    {
                        <a asp-action="Transactions" asp-route-id="@Model.Entity.Id" class="btn btn-sm btn-link">@Localizer["View All"]</a>
                    }
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover" id="transactionTable">
                            <thead>
                                <tr>
                                    <th>@Localizer["Date"]</th>
                                    <th>@Localizer["Description"]</th>
                                    <th>@Localizer["From"]</th>
                                    <th>@Localizer["To"]</th>
                                    <th>@Localizer["Amount"]</th>
                                    <th>@Localizer["Supporting Materials"]</th>
                                    <th>@Localizer["Fix Error"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.RecentTransactions)
                                {
                                    <tr>
                                        <td>@t.TransactionTime.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@t.Description</td>
                                        <td>@t.SourceAccount?.AccountName</td>
                                        <td>@t.DestinationAccount?.AccountName</td>
                                        <td>
                                            @t.Amount.ToString("N2") @t.SourceAccount?.Currency
                                            @if (t.ExchangeRate != 1)
                                            {
                                                <br />
                                                <small class="text-muted">
                                                    (@((t.Amount * t.ExchangeRate).ToString("N2")) @t.DestinationAccount?.Currency)
                                                </small>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(t.InvoicePath))
                                            {
                                                <a href="@StorageService.RelativePathToInternetUrl(t.InvoicePath, true)" target="_blank" title="@Localizer["Invoice"]">
                                                    <i class="fas fa-file-invoice"></i>
                                                </a>
                                            }
                                            @if (!string.IsNullOrEmpty(t.MT103Path))
                                            {
                                                <a href="@StorageService.RelativePathToInternetUrl(t.MT103Path, true)" target="_blank" title="MT103">
                                                    <i class="fas fa-file-contract"></i>
                                                </a>
                                            }
                                            @if (!string.IsNullOrEmpty(t.PaymentVoucherPath))
                                            {
                                                <a href="@StorageService.RelativePathToInternetUrl(t.PaymentVoucherPath, true)" target="_blank" title="@Localizer["Voucher"]">
                                                    <i class="fas fa-receipt"></i>
                                                </a>
                                            }

                                            @if (string.IsNullOrEmpty(t.InvoicePath) && string.IsNullOrEmpty(t.MT103Path) && string.IsNullOrEmpty(t.PaymentVoucherPath))
                                            {
                                                <i class="fas fa-paperclip text-gray-300" title="@Localizer["No Material"]"></i>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="EditTransaction" asp-route-id="@t.Id" asp-route-entityId="@Model.Entity.Id" title="@Localizer["Edit"]">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Health Metrics -->
        <div class="col-xl-4 col-lg-5">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">@Localizer["Health Metrics"]</h6>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            @Localizer["Monthly Burn Rate"] (@Model.Entity.BaseCurrency)
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.MonthlyBurnRate.ToString("N2")</div>
                    </div>
                    <div>
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                            @Localizer["Runway"]
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            @if (Model.RunwayMonths.HasValue)
                            {
                                @Model.RunwayMonths.Value.ToString("N1") @Localizer["Months"]
                            }
                            else
                            {
                                <span class="text-success">∞</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        $(document).ready(function () {
            $('#transactionTable').DataTable({
                "destroy": true,
                "responsive": true,
                "paging": true,
                "pageLength": 25,
                "searching": true,
                "info": false,
                "order": [[0, "desc"]]
            });
        });
    </script>
}