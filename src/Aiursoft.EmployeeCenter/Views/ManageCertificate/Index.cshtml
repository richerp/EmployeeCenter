@model Aiursoft.EmployeeCenter.Models.CertificateViewModels.IndexViewModel
@{
    ViewData["Title"] = Localizer["Manage Printing"];
}

<div class="container-fluid p-0">
    <h1 class="h3 mb-3">@Localizer["Manage Printing"]</h1>

    <div class="row">
        <div class="col-12 col-xl-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">@Localizer["Print Certificates for Employee"]</h5>
                    <h6 class="card-subtitle text-muted">@Localizer["Search for an employee to print their certificates."]</h6>
                </div>
                <div class="card-body">
                    <form asp-controller="Certificate" asp-action="Print" method="post" target="_blank">
                        <div class="mb-3">
                            <label class="form-label">@Localizer["Employee"]</label>
                            <partial name="_UserSelector" model='("userId", "userName", "", "")' />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@Localizer["Certificate Type"]</label>
                            <select name="type" class="form-select">
                                <option value="Employment">@Localizer["Certificate of Employment"]</option>
                                <option value="Income">@Localizer["Certificate of Income"]</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@Localizer["Language"]</label>
                            <div>
                                <label class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="lang" value="zh-CN" checked>
                                    <span class="form-check-label">
                                        中文 (Chinese)
                                    </span>
                                </label>
                                <label class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="lang" value="en-US">
                                    <span class="form-check-label">
                                        English
                                    </span>
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="align-middle" data-lucide="printer"></i> @Localizer["Print"]
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
