@model Aiursoft.EmployeeCenter.Models.AssetsViewModels.ManageCategoriesViewModel

<h1 class="h3 mb-3">@Localizer["Asset Categories"]</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Existing Categories"]</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@Localizer["Name"]</th>
                            <th>@Localizer["Code"]</th>
                            <th>@Localizer["References"]</th>
                            <th>@Localizer["Action"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model.Categories)
                        {
                            <tr>
                                <td>@category.Name</td>
                                <td><code>@category.Code</code></td>
                                <td>@category.Models.Count</td>
                                <td>
                                    @if (category.Models.Any())
                                    {
                                        <button class="btn btn-sm btn-secondary" disabled>@Localizer["Delete"]</button>
                                    }
                                    else
                                    {
                                        <form asp-action="DeleteCategory" method="post" onsubmit="return confirm(getLocalizedText('delete-confirm', 'Are you sure to delete this category?'));">
                                            <input type="hidden" name="id" value="@category.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger">@Localizer["Delete"]</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Add New Category"]</h5>
            </div>
            <div class="card-body">
                <form asp-action="CreateCategory">
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Category Name"]</label>
                        <input asp-for="NewName" class="form-control" required placeholder="@Localizer["e.g. Laptop"]" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Code Prefix"]</label>
                        <input asp-for="NewCode" class="form-control" required placeholder="@Localizer["e.g. LAP"]" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">@Localizer["Add Category"]</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-light">@Localizer["Back to Assets"]</a>
</div>

<div id="loc-data" class="d-none">
    <span data-key="delete-confirm">@Localizer["Are you sure to delete this category?"]</span>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <partial name="_LocalizationHelper" />
}
