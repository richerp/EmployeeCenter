@model Aiursoft.EmployeeCenter.Models.AssetsViewModels.AssignAssetViewModel

<h1 class="h3 mb-3">@Localizer["Assign Asset"]: <code>@Model.AssetTag</code> (@Model.ModelName)</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Assign">
            <input type="hidden" asp-for="AssetId" />
            <input type="hidden" asp-for="AssetTag" />
            <input type="hidden" asp-for="ModelName" />

            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Assignment Details"]</h5>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="AssigneeId" class="form-label"></label>
                        <div class="input-group">
                            <select asp-for="AssigneeId" class="form-select" asp-items="@(new SelectList(Model.AllUsers, "Id", "DisplayName"))">
                                <option value="">-- @Localizer["Select User"] --</option>
                            </select>
                            <a asp-controller="Users" asp-action="Create" target="_blank" class="btn btn-outline-secondary" title="@Localizer["New"]">
                                <i class="align-middle" data-lucide="plus-circle"></i>
                            </a>
                            <button type="button" class="btn btn-outline-secondary reload-dropdown" 
                                    data-url="@Url.Action("GetUsers")" 
                                    data-target="AssigneeId" 
                                    data-placeholder="@Localizer["Select User"]"
                                    data-name-key="displayName"
                                    title="@Localizer["Reload"]">
                                <i class="align-middle" data-lucide="rotate-cw"></i>
                            </button>
                        </div>
                        <span asp-validation-for="AssigneeId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="@Localizer["Optional notes for this assignment..."]"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>
                </div>
                <div class="card-footer text-end">
                    <button type="submit" class="btn btn-success">@Localizer["Assign Asset"]</button>
                    <a asp-action="Index" class="btn btn-light">@Localizer["Cancel"]</a>
                </div>
            </div>
        </form>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Notice"]</h5>
            </div>
            <div class="card-body">
                <p>@Localizer["When you assign an asset, the status will change to"] <span class="badge bg-warning">@Localizer["Pending Accept"]</span>.</p>
                <p>@Localizer["The assigned employee will need to log in and confirm the receipt of the asset before it officially becomes"] <span class="badge bg-success">@Localizer["In Use"]</span>.</p>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function reloadDropdown(url, targetId, placeholder, groupByKey = null, nameKey = "name", idKey = "id") {
                const target = document.getElementById(targetId);
                const originalValue = target.value;
                const reloadBtn = document.querySelector(`.reload-dropdown[data-target="${targetId}"]`);
                const icon = reloadBtn.querySelector('i');
                
                icon.classList.add('spin');

                fetch(url)
                    .then(response => response.json())
                    .then(data => {
                        target.innerHTML = '';
                        const defaultOption = document.createElement('option');
                        defaultOption.value = '';
                        defaultOption.textContent = '-- ' + placeholder + ' --';
                        target.appendChild(defaultOption);

                        if (groupByKey) {
                            const groups = {};
                            data.forEach(item => {
                                const groupName = item[groupByKey] || 'Other';
                                if (!groups[groupName]) {
                                    groups[groupName] = document.createElement('optgroup');
                                    groups[groupName].label = groupName;
                                    target.appendChild(groups[groupName]);
                                }
                                const option = document.createElement('option');
                                option.value = item[idKey];
                                option.textContent = item[nameKey];
                                if (item[idKey].toString() === originalValue.toString()) {
                                    option.selected = true;
                                }
                                groups[groupName].appendChild(option);
                            });
                        } else {
                            data.forEach(item => {
                                const option = document.createElement('option');
                                option.value = item[idKey];
                                option.textContent = item[nameKey];
                                if (item[idKey].toString() === originalValue.toString()) {
                                    option.selected = true;
                                }
                                target.appendChild(option);
                            });
                        }
                    })
                    .catch(error => console.error('Error reloading dropdown:', error))
                    .finally(() => {
                        icon.classList.remove('spin');
                    });
            }

            document.querySelectorAll('.reload-dropdown').forEach(btn => {
                btn.addEventListener('click', function () {
                    const url = this.dataset.url;
                    const target = this.dataset.target;
                    const placeholder = this.dataset.placeholder;
                    const groupByKey = this.dataset.groupBy;
                    const nameKey = this.dataset.nameKey || 'name';
                    const idKey = this.dataset.idKey || 'id';
                    reloadDropdown(url, target, placeholder, groupByKey, nameKey, idKey);
                });
            });
        });
    </script>
}
