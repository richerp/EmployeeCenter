@model Aiursoft.EmployeeCenter.Models.AssetsViewModels.ManageVendorsViewModel

<h1 class="h3 mb-3">@Localizer["Vendors"]</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Existing Vendors"]</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@Localizer["Name"]</th>
                            <th>@Localizer["Contact Info"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model.Vendors)
                        {
                            <tr>
                                <td>@v.Name</td>
                                <td>@v.ContactInfo</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Add New Vendor"]</h5>
            </div>
            <div class="card-body">
                <form asp-action="CreateVendor">
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Vendor Name"]</label>
                        <input asp-for="NewName" class="form-control" required placeholder="e.g. JD.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Contact Info"]</label>
                        <input asp-for="NewContactInfo" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">@Localizer["Add Vendor"]</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-light">@Localizer["Back to Assets"]</a>
</div>
