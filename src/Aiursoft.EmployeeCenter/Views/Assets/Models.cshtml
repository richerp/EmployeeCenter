@model Aiursoft.EmployeeCenter.Models.AssetsViewModels.ManageModelsViewModel

<h1 class="h3 mb-3">@Localizer["Asset Models"]</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Existing Models"]</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@Localizer["Category"]</th>
                            <th>@Localizer["Brand"]</th>
                            <th>@Localizer["Model Name"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model.Models)
                        {
                            <tr>
                                <td>@m.Category.Name</td>
                                <td>@m.Brand</td>
                                <td>@m.ModelName</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Add New Model"]</h5>
            </div>
            <div class="card-body">
                <form asp-action="CreateModel">
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Category"]</label>
                        <div class="input-group">
                            <select asp-for="NewCategoryId" class="form-select" asp-items="@(new SelectList(Model.AllCategories, "Id", "Name"))" required>
                                <option value="">-- @Localizer["Select Category"] --</option>
                            </select>
                            <a asp-action="Categories" target="_blank" class="btn btn-outline-secondary" title="@Localizer["New"]">
                                <i class="align-middle" data-lucide="plus-circle"></i>
                            </a>
                            <button type="button" class="btn btn-outline-secondary reload-dropdown" 
                                    data-url="@Url.Action("GetCategories")" 
                                    data-target="NewCategoryId" 
                                    data-placeholder="@Localizer["Select Category"]"
                                    title="@Localizer["Reload"]">
                                <i class="align-middle" data-lucide="rotate-cw"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Brand"]</label>
                        <input asp-for="NewBrand" class="form-control" required placeholder="e.g. Apple" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Model Name"]</label>
                        <input asp-for="NewModelName" class="form-control" required placeholder="e.g. MacBook Pro M3" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Specs"]</label>
                        <textarea asp-for="NewSpecs" class="form-control" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">@Localizer["Add Model"]</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-light">@Localizer["Back to Assets"]</a>
</div>

@section scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function reloadDropdown(url, targetId, placeholder, groupByKey = null, nameKey = "name", idKey = "id") {
                const target = document.getElementById(targetId);
                const originalValue = target.value;
                const reloadBtn = document.querySelector(`.reload-dropdown[data-target="${targetId}"]`);
                const icon = reloadBtn.querySelector('i');
                
                icon.classList.add('spin');

                fetch(url)
                    .then(response => response.json())
                    .then(data => {
                        target.innerHTML = '';
                        const defaultOption = document.createElement('option');
                        defaultOption.value = '';
                        defaultOption.textContent = '-- ' + placeholder + ' --';
                        target.appendChild(defaultOption);

                        if (groupByKey) {
                            const groups = {};
                            data.forEach(item => {
                                const groupName = item[groupByKey] || 'Other';
                                if (!groups[groupName]) {
                                    groups[groupName] = document.createElement('optgroup');
                                    groups[groupName].label = groupName;
                                    target.appendChild(groups[groupName]);
                                }
                                const option = document.createElement('option');
                                option.value = item[idKey];
                                option.textContent = item[nameKey];
                                if (item[idKey].toString() === originalValue.toString()) {
                                    option.selected = true;
                                }
                                groups[groupName].appendChild(option);
                            });
                        } else {
                            data.forEach(item => {
                                const option = document.createElement('option');
                                option.value = item[idKey];
                                option.textContent = item[nameKey];
                                if (item[idKey].toString() === originalValue.toString()) {
                                    option.selected = true;
                                }
                                target.appendChild(option);
                            });
                        }
                    })
                    .catch(error => console.error('Error reloading dropdown:', error))
                    .finally(() => {
                        icon.classList.remove('spin');
                    });
            }

            document.querySelectorAll('.reload-dropdown').forEach(btn => {
                btn.addEventListener('click', function () {
                    const url = this.dataset.url;
                    const target = this.dataset.target;
                    const placeholder = this.dataset.placeholder;
                    const groupByKey = this.dataset.groupBy;
                    const nameKey = this.dataset.nameKey || 'name';
                    const idKey = this.dataset.idKey || 'id';
                    reloadDropdown(url, target, placeholder, groupByKey, nameKey, idKey);
                });
            });
        });
    </script>
}
