@model Aiursoft.EmployeeCenter.Models.HolidayAdjustmentViewModels.IndexViewModel
@{
    ViewData["Title"] = "Holiday Adjustments";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">@ViewData["Title"]</h1>
    <a asp-action="Create" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
        <i class="fas fa-plus fa-sm text-white-50"></i> Create New Adjustment
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">All Adjustments</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered datatable" width="100%">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Reason</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Adjustments)
                    {
                        <tr>
                            <td data-order="@item.Date.ToString("yyyyMMdd")">@item.Date.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (item.Type == HolidayType.WorkDay)
                                {
                                    <span class="badge badge-warning">Work Day</span>
                                }
                                else
                                {
                                    <span class="badge badge-success">Rest Day</span>
                                }
                            </td>
                            <td>@item.Reason</td>
                            <td>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this adjustment?');">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
