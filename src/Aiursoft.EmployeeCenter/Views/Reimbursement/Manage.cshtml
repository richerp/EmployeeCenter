@using Aiursoft.EmployeeCenter.Entities
@model Aiursoft.EmployeeCenter.Models.ReimbursementViewModels.ManageIndexViewModel
@{
    ViewData["Title"] = "Reimbursement Approval Center";
}

<div class="container-xl">
    <div class="page-header d-print-none">
        <div class="row align-items-center">
            <div class="col">
                <h2 class="page-title">
                    Reimbursement Approval Center
                </h2>
                <div class="text-muted mt-1">Review and process reimbursement requests from employees.</div>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title">Pending Requests (@Model.PendingRequests.Count)</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter card-table">
                    <thead>
                        <tr>
                            <th>Submitter</th>
                            <th>Purpose</th>
                            <th>Amount</th>
                            <th>Submitted At</th>
                            <th class="w-1"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PendingRequests.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No pending requests.</td>
                            </tr>
                        }
                        @foreach (var item in Model.PendingRequests)
                        {
                            <tr>
                                <td>@item.Submitter?.DisplayName</td>
                                <td>@item.Purpose</td>
                                <td>@item.Amount.ToString("C")</td>
                                <td>@item.SubmittedAt.ToString("g")</td>
                                <td>
                                    <div class="btn-list flex-nowrap">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-white btn-sm">
                                            Review
                                        </a>
                                        <form asp-action="Acknowledge" asp-route-id="@item.Id" method="post">
                                            <button type="submit" class="btn btn-info btn-sm">Acknowledge</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title">Acknowledged (Wait for Payment) (@Model.AcknowledgedRequests.Count)</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter card-table">
                    <thead>
                        <tr>
                            <th>Submitter</th>
                            <th>Purpose</th>
                            <th>Amount</th>
                            <th>Acknowledged At</th>
                            <th class="w-1"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.AcknowledgedRequests.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No acknowledged requests waiting for payment.</td>
                            </tr>
                        }
                        @foreach (var item in Model.AcknowledgedRequests)
                        {
                            <tr>
                                <td>@item.Submitter?.DisplayName</td>
                                <td>@item.Purpose</td>
                                <td>@item.Amount.ToString("C")</td>
                                <td>@item.ReviewedAt?.ToString("g")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-white btn-sm">
                                        Process
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Recent History (Last 100)</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter card-table table-striped">
                    <thead>
                        <tr>
                            <th>Submitter</th>
                            <th>Purpose</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Reviewed By</th>
                            <th>Processed At</th>
                            <th class="w-1"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.HistoryRequests)
                        {
                            <tr>
                                <td>@item.Submitter?.DisplayName</td>
                                <td>@item.Purpose</td>
                                <td>@item.Amount.ToString("C")</td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case ReimbursementStatus.Reimbursed:
                                            <span class="badge bg-success">Reimbursed</span>
                                            break;
                                        case ReimbursementStatus.Rejected:
                                            <span class="badge bg-danger">Rejected</span>
                                            break;
                                        case ReimbursementStatus.Revoked:
                                            <span class="badge bg-warning">Revoked</span>
                                            break;
                                    }
                                </td>
                                <td>@item.ReviewedBy?.DisplayName</td>
                                <td>@(item.ReviewedAt?.ToString("g") ?? item.SubmittedAt.ToString("g"))</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-white btn-sm">
                                        Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
