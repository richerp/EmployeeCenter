@using System.IO
@model Aiursoft.EmployeeCenter.Models.ReimbursementViewModels.EditViewModel
@{
    ViewData["Title"] = "Edit Reimbursement Request";
}

<div class="container-xl">
    <div class="page-header d-print-none">
        <div class="row align-items-center">
            <div class="col">
                <h2 class="page-title">
                    Edit Reimbursement Request
                </h2>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ExpenseTime" class="form-label"></label>
                            <input asp-for="ExpenseTime" class="form-control" type="date" />
                            <span asp-validation-for="ExpenseTime" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Category" class="form-label"></label>
                            <select asp-for="Category" class="form-select">
                                <option value="">-- Select Category --</option>
                                <option value="Transport">Transport (交通费)</option>
                                <option value="Meals">Meals (餐饮费)</option>
                                <option value="Procurement">Procurement (采购费)</option>
                                <option value="Travel">Travel (差旅费)</option>
                                <option value="Others">Others (其他)</option>
                            </select>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Purpose" class="form-label"></label>
                        <input asp-for="Purpose" class="form-control" placeholder="What was this expense for?" />
                        <span asp-validation-for="Purpose" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SupportingEmail" class="form-label"></label>
                        <textarea asp-for="SupportingEmail" class="form-control" rows="3" placeholder="Paste supporting email content or other context here..."></textarea>
                        <span asp-validation-for="SupportingEmail" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Amount" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="InvoiceFile" class="form-label"></label>
                            <input asp-for="InvoiceFile" class="form-control" type="file" />
                            <span asp-validation-for="InvoiceFile" class="text-danger"></span>
                            @if (!string.IsNullOrEmpty(Model.ExistingInvoicePath))
                            {
                                <div class="text-muted small mt-1">
                                    Current file: @System.IO.Path.GetFileName(Model.ExistingInvoicePath) (uploading a new one will replace it)
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" name="SaveAsDraft" value="true" class="btn btn-secondary">
                            Keep as Draft
                        </button>
                        <button type="submit" name="SaveAsDraft" value="false" class="btn btn-primary">
                            Submit Request
                        </button>
                        <a asp-action="Index" class="btn btn-link">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


