@using Aiursoft.EmployeeCenter.Authorization
@using Microsoft.AspNetCore.Authorization
@using Aiursoft.EmployeeCenter.Services.FileStorage
@using Aiursoft.EmployeeCenter.Entities
@model Aiursoft.EmployeeCenter.Models.ReportLineViewModels.IndexViewModel
@inject IAuthorizationService AuthorizationService
@inject StorageService StorageService

@functions {
    string GetSafeId(string id) => "u_" + id.Replace("-", "_");
    
    string GetNodeLabel(User user) 
    {
        var avatarUrl = StorageService.RelativePathToInternetUrl(user.AvatarRelativePath) + "?w=50&square=true";
        var label = $"<img src='{avatarUrl}' width='25' height='25' /> {user.DisplayName}";
        if (!string.IsNullOrEmpty(user.JobLevel))
        {
            label += $"<br/><small>{user.JobLevel}</small>";
        }
        return $"\"{label}\"";
    }
}

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Report Line"]</h3>
    </div>
</div>

@if (Model.Error != null)
{
    <div class="alert alert-danger" role="alert">
        @Model.Error
    </div>
}

@if ((await AuthorizationService.AuthorizeAsync(User, AppPermissionNames.CanViewReportLine)).Succeeded)
{
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="card-title mb-0">@Localizer["Search Person"]</h5>
        </div>
        <div class="card-body">
            <div class="row align-items-end">
                <div class="col-md-8">
                    <partial name="_UserSelector" model='("TargetUserId", "TargetUserName", "", "")' />
                </div>
                <div class="col-md-4 mb-3">
                    <button type="button" class="btn btn-primary" onclick="viewTargetReportLine()">@Localizer["View Report Line"]</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function viewTargetReportLine() {
            const targetId = document.getElementById('user-id-hidden-TargetUserId').value;
            if (targetId) {
                window.location.href = '/ReportLine/Index/' + targetId;
            } else {
                alert('@Localizer["Please select a user first."]');
            }
        }
    </script>
}

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="network"></i> @Localizer["Visual Report Line"]</h5>
    </div>
    <div class="card-body overflow-auto">
        <div class="mermaid text-center">
            graph TD
            classDef targetUser fill:#f9f,stroke:#333,stroke-width:2px;
            classDef manager fill:#e1f5fe,stroke:#01579b;
            classDef peer fill:#fff3e0,stroke:#e65100;
            classDef subordinate fill:#e8f5e9,stroke:#1b5e20;

            @{
                var chain = Model.ManagerChain.AsEnumerable().Reverse().ToList();
                for (int i = 0; i < chain.Count; i++)
                {
                    var m = chain[i];
                    <text>@GetSafeId(m.Id) [@Html.Raw(GetNodeLabel(m))]:::manager</text>
                    <text>click @GetSafeId(m.Id) "/ReportLine/Index/@m.Id"</text>
                    if (i < chain.Count - 1)
                    {
                        var next = chain[i+1];
                        <text>@GetSafeId(m.Id) --> @GetSafeId(next.Id)</text>
                    }
                    else
                    {
                        <text>@GetSafeId(m.Id) --> @GetSafeId(Model.TargetUser.Id)</text>
                    }
                }
            }

            @GetSafeId(Model.TargetUser.Id) [@Html.Raw(GetNodeLabel(Model.TargetUser))]:::targetUser
            click @GetSafeId(Model.TargetUser.Id) "/ReportLine/Index/@Model.TargetUser.Id"

            @foreach (var peer in Model.Peers)
            {
                if (Model.TargetUser.ManagerId != null)
                {
                    <text>@GetSafeId(Model.TargetUser.ManagerId) --> @GetSafeId(peer.Id) [@Html.Raw(GetNodeLabel(peer))]:::peer</text>
                    <text>click @GetSafeId(peer.Id) "/ReportLine/Index/@peer.Id"</text>
                }
            }

            @foreach (var sub in Model.Subordinates)
            {
                <text>@GetSafeId(Model.TargetUser.Id) --> @GetSafeId(sub.Id) [@Html.Raw(GetNodeLabel(sub))]:::subordinate</text>
                <text>click @GetSafeId(sub.Id) "/ReportLine/Index/@sub.Id"</text>
            }
        </div>
    </div>
    <div class="card-footer text-muted">
        <div class="d-flex justify-content-center gap-3">
            <span><span class="badge" style="background-color: #e1f5fe; border: 1px solid #01579b; color: #01579b;">&nbsp;</span> @Localizer["Manager"]</span>
            <span><span class="badge" style="background-color: #f9f; border: 1px solid #333; color: #333;">&nbsp;</span> @Localizer["Target"]</span>
            <span><span class="badge" style="background-color: #fff3e0; border: 1px solid #e65100; color: #e65100;">&nbsp;</span> @Localizer["Peer"]</span>
            <span><span class="badge" style="background-color: #e8f5e9; border: 1px solid #1b5e20; color: #1b5e20;">&nbsp;</span> @Localizer["Subordinate"]</span>
        </div>
    </div>
</div>

<script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
    mermaid.initialize({ 
        startOnLoad: true,
        securityLevel: 'loose',
        theme: 'default'
    });
</script>

<style>
    .mermaid {
        min-height: 400px;
    }
    
    .mermaid svg {
        max-width: 100% !important;
        height: auto !important;
    }
</style>
