@using Aiursoft.EmployeeCenter.Authorization
@using Microsoft.AspNetCore.Authorization
@using Aiursoft.EmployeeCenter.Services.FileStorage
@model Aiursoft.EmployeeCenter.Models.ReportLineViewModels.IndexViewModel
@inject IAuthorizationService AuthorizationService
@inject StorageService StorageService

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Report Line"]</h3>
    </div>
</div>

@if (Model.Error != null)
{
    <div class="alert alert-danger" role="alert">
        @Model.Error
    </div>
}

@if ((await AuthorizationService.AuthorizeAsync(User, AppPermissionNames.CanViewReportLine)).Succeeded)
{
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="card-title mb-0">@Localizer["Search Person"]</h5>
        </div>
        <div class="card-body">
            <div class="row align-items-end">
                <div class="col-md-8">
                    <partial name="_UserSelector" model='("TargetUserId", "TargetUserName", "", "")' />
                </div>
                <div class="col-md-4 mb-3">
                    <button type="button" class="btn btn-primary" onclick="viewTargetReportLine()">@Localizer["View Report Line"]</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function viewTargetReportLine() {
            const targetId = document.getElementById('user-id-hidden-TargetUserId').value;
            if (targetId) {
                window.location.href = '/ReportLine/Index/' + targetId;
            } else {
                alert('@Localizer["Please select a user first."]');
            }
        }
    </script>
}

<div class="row">
    @* Manager Chain *@
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="chevron-up"></i> @Localizer["Management Chain"]</h5>
            </div>
            <div class="card-body">
                <div class="list-group">
                    @foreach (var manager in Model.ManagerChain.AsEnumerable().Reverse())
                    {
                        <a asp-action="Index" asp-route-id="@manager.Id" class="list-group-item list-group-item-action d-flex align-items-center">
                            <img src="@StorageService.RelativePathToInternetUrl(manager.AvatarRelativePath)?w=100&square=true" class="rounded-circle me-2" width="30" height="30" alt="@manager.DisplayName">
                            <div>
                                <strong>@manager.DisplayName</strong><br>
                                <small class="text-muted">@manager.JobLevel</small>
                            </div>
                        </a>
                        <div class="text-center my-1"><i data-lucide="arrow-down" class="text-muted"></i></div>
                    }
                    <div class="list-group-item active d-flex align-items-center">
                        <img src="@StorageService.RelativePathToInternetUrl(Model.TargetUser.AvatarRelativePath)?w=100&square=true" class="rounded-circle me-2" width="30" height="30" alt="@Model.TargetUser.DisplayName">
                        <div>
                            <strong>@Model.TargetUser.DisplayName</strong><br>
                            <small>@Model.TargetUser.JobLevel</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Peers and Subordinates *@
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="users"></i> @Localizer["Peers"]</h5>
            </div>
            <div class="card-body">
                @if (Model.Peers.Any())
                {
                    <div class="row">
                        @foreach (var peer in Model.Peers)
                        {
                            <div class="col-sm-6 col-lg-4 mb-3">
                                <a asp-action="Index" asp-route-id="@peer.Id" class="text-decoration-none">
                                    <div class="card border h-100 mb-0 shadow-sm hover-shadow transition">
                                        <div class="card-body p-3 d-flex align-items-center">
                                            <img src="@StorageService.RelativePathToInternetUrl(peer.AvatarRelativePath)?w=100&square=true" class="rounded-circle me-2" width="40" height="40" alt="@peer.DisplayName">
                                            <div class="overflow-hidden">
                                                <div class="text-truncate font-weight-bold text-dark">@peer.DisplayName</div>
                                                <small class="text-muted text-truncate d-block">@peer.JobLevel</small>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">@Localizer["No peers found."]</p>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="user-plus"></i> @Localizer["Direct Reports"]</h5>
            </div>
            <div class="card-body">
                @if (Model.Subordinates.Any())
                {
                    <div class="row">
                        @foreach (var sub in Model.Subordinates)
                        {
                            <div class="col-sm-6 col-lg-4 mb-3">
                                <a asp-action="Index" asp-route-id="@sub.Id" class="text-decoration-none">
                                    <div class="card border h-100 mb-0 shadow-sm hover-shadow transition">
                                        <div class="card-body p-3 d-flex align-items-center">
                                            <img src="@StorageService.RelativePathToInternetUrl(sub.AvatarRelativePath)?w=100&square=true" class="rounded-circle me-2" width="40" height="40" alt="@sub.DisplayName">
                                            <div class="overflow-hidden">
                                                <div class="text-truncate font-weight-bold text-dark">@sub.DisplayName</div>
                                                <small class="text-muted text-truncate d-block">@sub.JobLevel</small>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">@Localizer["No direct reports found."]</p>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    .transition {
        transition: all .2s ease-in-out;
    }
</style>
