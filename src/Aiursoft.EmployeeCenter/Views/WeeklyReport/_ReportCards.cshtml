@using Aiursoft.EmployeeCenter.Services
@using Aiursoft.EmployeeCenter.Authorization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@model List<WeeklyReport>
@inject Aiursoft.EmployeeCenter.Services.FileStorage.StorageService StorageService
@inject UserManager<User> UserManager
@inject IAuthorizationService AuthorizationService

@{
    var currentUserId = UserManager.GetUserId(User);
    var canManageAnyone = (await AuthorizationService.AuthorizeAsync(User, AppPermissionNames.CanManageAnyoneWeeklyReport)).Succeeded;
}

@foreach (var report in Model)
{
    <div class="card mb-4 weekly-report-card" 
         data-create-time="@report.CreateTime.ToString("O")"
         data-week-start-date="@report.WeekStartDate.ToString("O")">
        <div class="card-header d-flex align-items-center justify-content-between">
            <a asp-controller="Users" asp-action="Details" asp-route-id="@report.UserId" class="d-flex align-items-center text-decoration-none">
                <img src="@(StorageService.RelativePathToInternetUrl(report.User.AvatarRelativePath) + "?w=100&square=true")" 
                     class="rounded-circle me-3" 
                     alt="@report.User.DisplayName" 
                     style="width: 48px; height: 48px; object-fit: cover;" />
                <div>
                    <h5 class="mb-0 fw-bold">@report.User.DisplayName</h5>
                    <div class="d-flex flex-column">
                        <small class="text-primary fw-semibold">
                            <i class="align-middle me-1" data-lucide="calendar" style="width: 14px; height: 14px;"></i>
                            @report.WeekStartDate.ToString("yyyy-MM-dd") ~ @report.WeekStartDate.AddDays(6).ToString("yyyy-MM-dd")
                        </small>
                        <small class="text-muted" data-utc-time="@report.CreateTime.ToHtmlDateTime()"></small>
                    </div>
                </div>
            </a>
            
            <div class="d-flex align-items-center">
                @if (report.UserId == currentUserId || canManageAnyone)
                {
                    if (canManageAnyone || report.CreateTime >= DateTime.UtcNow.AddDays(-28))
                    {
                        <a asp-action="Edit" asp-route-id="@report.Id" class="btn btn-sm btn-outline-primary me-2">
                            <i class="align-middle me-1" data-lucide="edit-3"></i> @Localizer["Edit"]
                        </a>
                    }
                    
                    <form asp-action="Delete" asp-route-id="@report.Id" method="post" onsubmit="return confirm('@Localizer["Are you sure you want to delete this weekly report?"]');" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="align-middle me-1" data-lucide="trash-2"></i> @Localizer["Delete"]
                        </button>
                    </form>
                }
            </div>
        </div>
        <div class="card-body pb-1">
            <div class="markdown-body">
                @MarkdownService.RenderMarkdown(report.Content)
            </div>
        </div>
    </div>
}
