@model Aiursoft.EmployeeCenter.Models.CompanyEntityViewModels.DetailsViewModel
@using Aiursoft.EmployeeCenter.Authorization
@using Microsoft.AspNetCore.Authorization
@using Aiursoft.EmployeeCenter.Services.FileStorage
@using System.Text
@inject IAuthorizationService AuthorizationService
@inject StorageService StorageService
@{
    var canManage = (await AuthorizationService.AuthorizeAsync(User, AppPermissionNames.CanManageCompanyEntities)).Succeeded;

    var summaryBuilder = new StringBuilder();
    summaryBuilder.AppendLine($"{Localizer["Company Name"].Value}: {Model.Entity.CompanyName}");
    summaryBuilder.AppendLine($"{Localizer["Entity Code"].Value}: {Model.Entity.EntityCode}");
    summaryBuilder.AppendLine($"{Localizer["Legal Rep / Director"].Value}: {Model.Entity.LegalRepresentative}");
    summaryBuilder.AppendLine($"{Localizer["Legal Rep Legal Name"].Value}: {Model.Entity.LegalRepresentativeLegalName}");
    summaryBuilder.AppendLine($"{Localizer["Address"].Value}: {Model.Entity.RegisteredAddress}");
    summaryBuilder.AppendLine($"{Localizer["Bank Info"].Value}: {Model.Entity.BankName}");
    summaryBuilder.AppendLine($"{Localizer["Account"].Value}: {Model.Entity.BankAccount}");
    summaryBuilder.AppendLine($"{Localizer["Account Name"].Value}: {Model.Entity.BankAccountName}");
    if (!string.IsNullOrEmpty(Model.Entity.SwiftCode))
    {
        summaryBuilder.AppendLine($"{Localizer["SWIFT Code"].Value}: {Model.Entity.SwiftCode}");
    }
    if (!string.IsNullOrEmpty(Model.Entity.BankCode))
    {
        summaryBuilder.AppendLine($"{Localizer["Bank Code"].Value}: {Model.Entity.BankCode}");
    }
    if (!string.IsNullOrEmpty(Model.Entity.BankAddress))
    {
        summaryBuilder.AppendLine($"{Localizer["Bank Address"].Value}: {Model.Entity.BankAddress}");
    }
    var summaryInfo = summaryBuilder.ToString();

    var fullBuilder = new StringBuilder();
    fullBuilder.AppendLine($"{Localizer["Company Name"].Value}: {Model.Entity.CompanyName}");
    fullBuilder.AppendLine($"{Localizer["English Name"].Value}: {Model.Entity.CompanyNameEnglish}");
    fullBuilder.AppendLine($"{Localizer["Entity Code"].Value}: {Model.Entity.EntityCode}");
    fullBuilder.AppendLine($"{Localizer["CI Number"].Value}: {Model.Entity.CINumber}");
    fullBuilder.AppendLine($"{Localizer["Registered Address"].Value}: {Model.Entity.RegisteredAddress}");
    fullBuilder.AppendLine($"{Localizer["Office Address"].Value}: {Model.Entity.OfficeAddress}");
    fullBuilder.AppendLine($"{Localizer["Zip Code"].Value}: {Model.Entity.ZipCode}");
    fullBuilder.AppendLine($"{Localizer["Legal Representative"].Value}: {Model.Entity.LegalRepresentative}");
    fullBuilder.AppendLine($"{Localizer["Legal Representative Legal Name"].Value}: {Model.Entity.LegalRepresentativeLegalName}");
    fullBuilder.AppendLine($"{Localizer["Company Type"].Value}: {Model.Entity.CompanyType}");
    if (Model.Entity.EstablishmentDate.HasValue)
    {
        fullBuilder.AppendLine($"{Localizer["Establishment"].Value}: {Model.Entity.EstablishmentDate.Value:yyyy-MM-dd}");
    }
    if (Model.Entity.ExpiryDate.HasValue)
    {
        fullBuilder.AppendLine($"{Localizer["Expiry Date"].Value}: {Model.Entity.ExpiryDate.Value:yyyy-MM-dd}");
    }
    fullBuilder.AppendLine($"{Localizer["Bank Name"].Value}: {Model.Entity.BankName}");
    fullBuilder.AppendLine($"{Localizer["Bank Account"].Value}: {Model.Entity.BankAccount}");
    fullBuilder.AppendLine($"{Localizer["Bank Account Name"].Value}: {Model.Entity.BankAccountName}");
    fullBuilder.AppendLine($"{Localizer["SWIFT Code"].Value}: {Model.Entity.SwiftCode}");
    fullBuilder.AppendLine($"{Localizer["Bank Code"].Value}: {Model.Entity.BankCode}");
    fullBuilder.AppendLine($"{Localizer["Bank Address"].Value}: {Model.Entity.BankAddress}");
    fullBuilder.AppendLine($"{Localizer["Registered Capital"].Value}: {Model.Entity.RegisteredCapital}");
    fullBuilder.AppendLine($"{Localizer["Status"].Value}: {Model.Entity.OperationStatus}");
    fullBuilder.AppendLine($"{Localizer["SCR Location"].Value}: {Model.Entity.SCRLocation}");
    fullBuilder.AppendLine($"{Localizer["Secretary"].Value}: {Model.Entity.CompanySecretary}");
    var fullInfo = fullBuilder.ToString();
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">@Localizer["Entity Details"]</h1>
        <div>
            <button class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm mr-2" data-text="@summaryInfo" onclick="copyToClipboard(this.getAttribute('data-text'))">
                <i class="fas fa-copy fa-sm text-white-50"></i> @Localizer["Copy Summary"]
            </button>
            @if (canManage)
            {
                <button class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm mr-2" data-text="@fullInfo" onclick="copyToClipboard(this.getAttribute('data-text'))">
                    <i class="fas fa-copy fa-sm text-white-50"></i> @Localizer["Copy Full Info"]
                </button>
                <a asp-controller="CompanyEntity" asp-action="Edit" asp-route-id="@Model.Entity.Id" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
                    <i class="fas fa-edit fa-sm text-white-50"></i> @Localizer["Edit"]
                </a>
            }
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <!-- Basic Info Card -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">@Localizer["Basic Information"]</h6>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">@Localizer["Company Name"]</dt>
                        <dd class="col-sm-8">@Model.Entity.CompanyName</dd>

                        @if(!string.IsNullOrEmpty(Model.Entity.CompanyNameEnglish))
                        {
                            <dt class="col-sm-4">@Localizer["English Name"]</dt>
                            <dd class="col-sm-8">@Model.Entity.CompanyNameEnglish</dd>
                        }

                        <dt class="col-sm-4">@Localizer["Entity Code"]</dt>
                        <dd class="col-sm-8">@Model.Entity.EntityCode</dd>

                        @if (canManage && !string.IsNullOrEmpty(Model.Entity.CINumber))
                        {
                            <dt class="col-sm-4">@Localizer["CI Number"]</dt>
                            <dd class="col-sm-8">@Model.Entity.CINumber</dd>
                        }

                        <dt class="col-sm-4">@Localizer["Legal Rep / Director"]</dt>
                        <dd class="col-sm-8">@Model.Entity.LegalRepresentative</dd>

                        @if (!string.IsNullOrEmpty(Model.Entity.LegalRepresentativeLegalName))
                        {
                            <dt class="col-sm-4">@Localizer["Legal Rep Legal Name"]</dt>
                            <dd class="col-sm-8">@Model.Entity.LegalRepresentativeLegalName</dd>
                        }

                        <dt class="col-sm-4">@Localizer["Address"]</dt>
                        <dd class="col-sm-8">
                            <p class="mb-0"><strong>Reg:</strong> @Model.Entity.RegisteredAddress</p>
                            <p class="mb-0"><strong>Office:</strong> @Model.Entity.OfficeAddress</p>
                            @if (!string.IsNullOrEmpty(Model.Entity.ZipCode))
                            {
                                <p class="mb-0"><strong>Zip:</strong> @Model.Entity.ZipCode</p>
                            }
                        </dd>

                        <dt class="col-sm-4">@Localizer["Bank Info"]</dt>
                        <dd class="col-sm-8">
                            <p class="mb-0"><strong>Name:</strong> @Model.Entity.BankName</p>
                            <p class="mb-0"><strong>Account:</strong> @Model.Entity.BankAccount</p>
                            <p class="mb-0"><strong>Account Name:</strong> @Model.Entity.BankAccountName</p>
                            @if (!string.IsNullOrEmpty(Model.Entity.SwiftCode))
                            {
                                <p class="mb-0"><strong>SWIFT:</strong> @Model.Entity.SwiftCode</p>
                            }
                            @if (!string.IsNullOrEmpty(Model.Entity.BankCode))
                            {
                                <p class="mb-0"><strong>Bank Code:</strong> @Model.Entity.BankCode</p>
                            }
                            @if (!string.IsNullOrEmpty(Model.Entity.BankAddress))
                            {
                                <p class="mb-0"><strong>Address:</strong> @Model.Entity.BankAddress</p>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <!-- Invoice Guide Card -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">@Localizer["Invoice Issuance Guide"]</h6>
                </div>
                <div class="card-body">
                    <p>@Localizer["Please show the following information to the merchant when making a payment:"]</p>

                    <div class="card bg-light mb-3">
                        <div class="card-body">
                            <h5 class="card-title text-primary font-weight-bold">@Model.Entity.CompanyName</h5>
                            <dl class="row mb-0">
                                <dt class="col-sm-4">@Localizer["Tax ID"]</dt>
                                <dd class="col-sm-8 text-body font-weight-bold">@Model.Entity.EntityCode</dd>

                                <dt class="col-sm-4">@Localizer["Address"]</dt>
                                <dd class="col-sm-8 small">@Model.Entity.RegisteredAddress</dd>

                                <dt class="col-sm-4">@Localizer["Bank"]</dt>
                                <dd class="col-sm-8 small">@Model.Entity.BankName</dd>

                                <dt class="col-sm-4">@Localizer["Account"]</dt>
                                <dd class="col-sm-8 text-body font-weight-bold">@Model.Entity.BankAccount</dd>

                                @if (!string.IsNullOrEmpty(Model.Entity.SwiftCode))
                                {
                                    <dt class="col-sm-4">@Localizer["SWIFT Code"]</dt>
                                    <dd class="col-sm-8 small">@Model.Entity.SwiftCode</dd>
                                }
                                
                                @if (!string.IsNullOrEmpty(Model.Entity.BankCode))
                                {
                                    <dt class="col-sm-4">@Localizer["Bank Code"]</dt>
                                    <dd class="col-sm-8 small">@Model.Entity.BankCode</dd>
                                }
                            </dl>
                        </div>
                    </div>

                    <hr />

                    <h6 class="font-weight-bold">@Localizer["Instructions for Employees"]</h6>
                    <ol class="pl-3">
                        <li class="mb-2">
                            <strong>@Localizer["Prefer Electronic Invoices (Fully Digitalized)"]</strong>:
                            @Localizer["Ask merchants for electronic invoices (PDF/OFD) sent to your email or employees@aiursoft.com."]
                            @Localizer["Avoid paper invoices to prevent loss."]
                        </li>
                        <li class="mb-2">
                             <strong>@Localizer["Reimbursement Categories"]</strong>:
                             @Localizer["Meals, Transportation, Communication, Electronics (Computers/Peripherals)."]
                             @Localizer["Must be real business expenses. No fake invoices."]
                        </li>
                        <li class="mb-2">
                             <strong>@Localizer["Special Cases"]</strong>:
                             @Localizer["Accommodation: Must issue VAT Special Invoice with full company name. Avoid fixed-amount paper invoices if possible."]
                        </li>
                    </ol>
                    <p class="small text-muted mb-0">
                        @Localizer["Tip: When incurring business or welfare expenses, please request an invoice. Prefer electronic invoices. Keep the original PDF."]
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <!-- Images & Files Card -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">@Localizer["Images & Files"]</h6>
                </div>
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.Entity.LogoPath))
                    {
                        <div class="mb-3">
                            <h6>@Localizer["Logo"]</h6>
                            <img src="@StorageService.RelativePathToInternetUrl(Model.Entity.LogoPath)" class="img-fluid" style="max-height: 100px;" alt="Logo">
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Entity.SealPath))
                    {
                        <div class="mb-3">
                            <h6>@Localizer["Official Seal"]</h6>
                            <img src="@StorageService.RelativePathToInternetUrl(Model.Entity.SealPath)" class="img-fluid" style="max-height: 100px;" alt="Seal">
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Entity.LicensePath))
                    {
                        <div class="mb-3">
                            <h6>@Localizer["Business Registration"]</h6>
                             <a href="@StorageService.RelativePathToInternetUrl(Model.Entity.LicensePath, isVault: Model.Entity.LicensePath.StartsWith("company-certs"))" target="_blank" class="btn btn-secondary btn-sm">
                                <i class="fas fa-file-download"></i> @Localizer["Download / View"]
                            </a>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Entity.OrganizationCertificatePath))
                    {
                        <div class="mb-3">
                            <h6>@Localizer["Organization Certificate"]</h6>
                             <a href="@StorageService.RelativePathToInternetUrl(Model.Entity.OrganizationCertificatePath, isVault: true)" target="_blank" class="btn btn-secondary btn-sm">
                                <i class="fas fa-file-download"></i> @Localizer["Download / View"]
                            </a>
                        </div>
                    }
                </div>
            </div>

            @if (canManage)
            {
                 <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">@Localizer["Administrative Details"]</h6>
                    </div>
                    <div class="card-body">
                         <dl class="row">
                            <dt class="col-sm-4">@Localizer["Company Type"]</dt>
                            <dd class="col-sm-8">@Model.Entity.CompanyType</dd>

                            <dt class="col-sm-4">@Localizer["Establishment"]</dt>
                            <dd class="col-sm-8">@(Model.Entity.EstablishmentDate.HasValue ? Html.Raw($"<label data-utc-time=\"{Model.Entity.EstablishmentDate.Value.ToHtmlDateTime()}\"></label>") : Localizer["N/A"].Value)</dd>

                            <dt class="col-sm-4">@Localizer["Expiry Date"]</dt>
                            <dd class="col-sm-8 @(Model.Entity.ExpiryDate < DateTime.UtcNow.AddMonths(3) ? "text-danger font-weight-bold" : "")">
                                @(Model.Entity.ExpiryDate.HasValue ? Html.Raw($"<label data-utc-time=\"{Model.Entity.ExpiryDate.Value.ToHtmlDateTime()}\"></label>") : Localizer["N/A"].Value)
                            </dd>

                            @if (!string.IsNullOrEmpty(Model.Entity.RegisteredCapital))
                            {
                                <dt class="col-sm-4">@Localizer["Reg Capital"]</dt>
                                <dd class="col-sm-8">@Model.Entity.RegisteredCapital</dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.Entity.OperationStatus))
                            {
                                <dt class="col-sm-4">@Localizer["Status"]</dt>
                                <dd class="col-sm-8">@Model.Entity.OperationStatus</dd>
                            }

                             @if (!string.IsNullOrEmpty(Model.Entity.SCRLocation))
                            {
                                <dt class="col-sm-4">@Localizer["SCR Location"]</dt>
                                <dd class="col-sm-8">@Model.Entity.SCRLocation</dd>
                            }

                             @if (!string.IsNullOrEmpty(Model.Entity.CompanySecretary))
                            {
                                <dt class="col-sm-4">@Localizer["Secretary"]</dt>
                                <dd class="col-sm-8">@Model.Entity.CompanySecretary</dd>
                            }
                         </dl>
                    </div>
                </div>
            }

            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">@Localizer["Associated Servers"]</h6>
                </div>
                <div class="card-body">
                    @if (Model.Servers.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var server in Model.Servers)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@server.Hostname</strong>
                                        <br/>
                                        <small class="text-muted">@server.ServerIp</small>
                                    </div>
                                    <a asp-controller="Servers" asp-action="Edit" asp-route-id="@server.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">@Localizer["No servers associated."]</p>
                    }
                </div>
            </div>

            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">@Localizer["Associated Intangible Assets"]</h6>
                </div>
                <div class="card-body">
                    @if (Model.IntangibleAssets.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var asset in Model.IntangibleAssets)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@asset.Name</strong>
                                        <br/>
                                        <small class="text-muted">@asset.Type - @asset.Status</small>
                                    </div>
                                    <a asp-controller="IntangibleAssets" asp-action="Details" asp-route-id="@asset.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">@Localizer["No intangible assets associated."]</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        function copyToClipboard(text) {
            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(text).then(function() {
                     alert('Copied to clipboard!');
                }, function(err) {
                     alert('Could not copy text: ', err);
                });
            } else {
                // Fallback for older browsers or non-secure context
                let textArea = document.createElement("textarea");
                textArea.value = text;
                textArea.style.position = "fixed";
                textArea.style.left = "-9999px";
                document.body.appendChild(textArea);
                textArea.focus();
                textArea.select();
                try {
                    document.execCommand('copy');
                    alert('Copied to clipboard!');
                } catch (err) {
                    alert('Unable to copy', err);
                }
                document.body.removeChild(textArea);
            }
        }
    </script>
}
