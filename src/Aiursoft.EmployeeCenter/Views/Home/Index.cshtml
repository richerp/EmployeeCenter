@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <link rel="stylesheet" href="~/styles/site.css" xmlns="http://www.w3.org/1999/html"/>
}

<vc:marketing-navbar></vc:marketing-navbar>

<section class="landing-intro text-bg-dark pt-5 pt-lg-6 pb-5 pb-lg-7">
    <div class="landing-intro-content container h-100">
        <div class="row align-items-center h-100">
            <div class="col-lg-5 mx-auto">
                <span class="badge badge-subtle-primary p-1">@Localizer["Enterprise Ready"]</span>
                <span class="badge badge-subtle-primary p-1">@Localizer["Offline Capable"]</span>
                <span class="badge badge-subtle-primary p-1">@Localizer["MIT Licence"]</span>
                <h1 id="main-slogan" class="my-4 text-white" style="font-size: 3rem;">
                    @Localizer["Employee Center"]
                </h1>
                <p class="text-lg text-white-50">
                    @Localizer["A fast, offline-deployable enterprise office center designed to streamline your internal operations."]
                    @Localizer["Manage employees, finances, assets, and more with a single, integrated platform."]
                </p>
                <div class="my-4">
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="layout-dashboard"></i> @Localizer["Go to Dashboard"]
                    </a>
                    <a class="btn btn-outline-light btn-lg btn-pill" href="https://github.com/aiursoftweb/employeecenter" target="_blank">
                        <i class="align-middle" data-lucide="github"></i> @Localizer["View on GitHub"]
                    </a>
                </div>
            </div>
            <div class="col-lg-7 d-none d-lg-flex mx-auto text-center">
                <div class="landing-intro-screenshot">
                    <img src="~/images/screenshot.png" alt="Employee Center Screenshot" class="img-fluid" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Capabilities"]</span>
            <h2 class="h1">@Localizer["Everything you need to run your company"]</h2>
            <p class="text-muted fs-lg">@Localizer["From HR to Finance, IT to Operations, Employee Center has you covered."]</p>
        </div>

        <div class="row">
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="database"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Multi-Database Support"]</h4>
                        <p class="fs-lg">@Localizer["Flexible storage options ensuring compatibility with your existing infrastructure."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="shield-check"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Advanced RBAC"]</h4>
                        <p class="fs-lg">@Localizer["Granular Role-Based Access Control to ensure data security and proper authorization."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="key"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Enterprise Login (OIDC)"]</h4>
                        <p class="fs-lg">@Localizer["Seamless integration with OpenID Connect providers for secure, single sign-on experience."]</p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="container"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Docker Offline Deployment"]</h4>
                        <p class="fs-lg">@Localizer["Deploy anywhere, even in air-gapped environments, with our robust Docker support."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="receipt"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Financial Registration"]</h4>
                        <p class="fs-lg">@Localizer["Streamline financial tracking and record-keeping for better transparency."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="network"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Report Line View"]</h4>
                        <p class="fs-lg">@Localizer["Visualize organizational structure and reporting hierarchies with clarity."]</p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="users"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Employee Management"]</h4>
                        <p class="fs-lg">@Localizer["Centralized system for maintaining up-to-date employee records and information."]</p>
                    </div>
                </div>
            </div>
             <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="banknote"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Payslip Distribution"]</h4>
                        <p class="fs-lg">@Localizer["Secure and efficient electronic distribution of monthly salary slips."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="lock"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Secret Distribution"]</h4>
                        <p class="fs-lg">@Localizer["Safely share sensitive credentials and company secrets with authorized personnel."]</p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="calendar-check"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Reimbursement Calendar"]</h4>
                        <p class="fs-lg">@Localizer["Track and manage expense reimbursements with an integrated calendar view."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="trending-up"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Promotion Management"]</h4>
                        <p class="fs-lg">@Localizer["Systematize the career progression and promotion processes for your team."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="monitor"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Asset Recording"]</h4>
                        <p class="fs-lg">@Localizer["Keep detailed inventory records of all company hardware and software assets."]</p>
                    </div>
                </div>
            </div>
            
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="coffee"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Leave Tracking"]</h4>
                        <p class="fs-lg">@Localizer["Efficiently manage employee leave requests and attendance records."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="alert-triangle"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Incident Management"]</h4>
                        <p class="fs-lg">@Localizer["Track, report, and resolve workplace incidents to ensure safety and compliance."]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-white">
    <div class="container position-relative z-3">
        <div class="row">
            <div class="col-md-12 mx-auto text-center">
                <div class="row">
                    <div class="col-lg-10 col-xl-9 mx-auto">
                        <div class="mb-4">
                            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Efficiency"]</span>
                            <h2 class="h1 mb-3">@Localizer["Boost Operational Efficiency"]</h2>
                            <p class="text-muted fs-lg">
                                @Localizer["Employee Center integrates disjointed processes into a unified workflow, eliminating manual errors and saving valuable time for your HR and Admin teams."]
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row justify-content-center">
             <div class="col-md-4 py-3 text-center">
                 <div class="card h-100 border-0 shadow-sm">
                     <div class="card-body">
                         <div class="display-4 text-primary mb-3">
                             <i data-lucide="clock"></i>
                         </div>
                         <h4 class="mt-3">@Localizer["Save Time"]</h4>
                         <p class="text-muted">@Localizer["Automated workflows for payroll, leave, and expenses mean less time on paperwork and more time on people."]</p>
                     </div>
                 </div>
             </div>
             <div class="col-md-4 py-3 text-center">
                 <div class="card h-100 border-0 shadow-sm">
                     <div class="card-body">
                         <div class="display-4 text-primary mb-3">
                             <i data-lucide="check-circle"></i>
                         </div>
                         <h4 class="mt-3">@Localizer["Accuracy"]</h4>
                         <p class="text-muted">@Localizer["Centralized data drastically reduces discrepancies in employee records and financial reporting."]</p>
                     </div>
                 </div>
             </div>
             <div class="col-md-4 py-3 text-center">
                 <div class="card h-100 border-0 shadow-sm">
                     <div class="card-body">
                         <div class="display-4 text-primary mb-3">
                             <i data-lucide="lock"></i>
                         </div>
                         <h4 class="mt-3">@Localizer["Security"]</h4>
                         <p class="text-muted">@Localizer["Enterprise-grade security features ensure your sensitive company data remains protected."]</p>
                     </div>
                 </div>
             </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container text-center">
        <div class="row">
            <div class="col-12 col-md-10 col-lg-9 col-xl-8 mx-auto">
                <h2 class="h1 mb-3">
                    @Localizer["Ready to modernize your office?"]
                </h2>
                <p class="text-muted fs-lg mb-4">
                    @Localizer["Join the growing number of companies optimizing their workforce management with Employee Center."]
                </p>
                <a asp-controller="Dashboard" asp-action="Index" class="align-middle btn btn-primary btn-pill btn-lg mt-n1">
                    <i data-lucide="rocket"></i>
                    <span class="ms-1">@Localizer["Get Started Now"]</span>
                </a>
            </div>
        </div>
    </div>
</section>

<vc:marketing-footer></vc:marketing-footer>
