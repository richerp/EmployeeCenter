@model Aiursoft.EmployeeCenter.Models.PayrollViewModels.IndexViewModel
<style>
    .clickable-row {
        cursor: pointer;
    }
</style>

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["My Payrolls"]</h3>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title">@Localizer["Historical Payrolls"]</h5>
        <h6 class="card-subtitle text-muted">@Localizer["A list of all your historical payroll records."]</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
            <tr>
                <th>@Localizer["Target Month"]</th>
                <th>@Localizer["Total Amount"]</th>
                <th>@Localizer["Created Time"]</th>
                <th class="text-end">@Localizer["Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Payrolls)
            {
                <tr class="clickable-row" data-href="@Url.Action("Details", new { id = item.Id })">
                    <td>@item.TargetMonth.ToString("yyyy-MM")</td>
                    <td>@item.TotalAmount.ToString("C")</td>
                    <td>@item.CreationTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                            <i class="align-middle" data-lucide="eye"></i> @Localizer["Details"]
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const rows = document.querySelectorAll(".clickable-row");
            rows.forEach(row => {
                row.addEventListener("click", function (event) {
                    const target = event.target;
                    if (!target.matches('a, a *, button, button *')) {
                        window.location.href = row.dataset.href;
                    }
                });
            });
        });
    </script>
}
