@model Aiursoft.EmployeeCenter.Models.CollectionRecordsViewModels.EditViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Edit collection record"]</h3>
        <p class="text-muted">@Localizer["For channel:"] @Model.Channel!.Payer?.CompanyName -> @Model.Channel!.Payee?.CompanyName</p>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ChannelId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ExpectedAmount" class="form-label"></label>
                    <input asp-for="ExpectedAmount" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="ExpectedAmount" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ActualAmount" class="form-label"></label>
                    <input asp-for="ActualAmount" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="ActualAmount" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="DueDate" class="form-label"></label>
                    <input asp-for="DueDate" class="form-control" type="date" />
                    <span asp-validation-for="DueDate" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PaidDate" class="form-label"></label>
                    <input asp-for="PaidDate" class="form-control" type="date" />
                    <span asp-validation-for="PaidDate" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ReceiptPath" class="form-label"></label>
                    <input asp-for="ReceiptPath" class="form-control" />
                    <span asp-validation-for="ReceiptPath" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="InvoicePath" class="form-label"></label>
                    <input asp-for="InvoicePath" class="form-control" />
                    <span asp-validation-for="InvoicePath" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="TransactionId" class="form-label"></label>
                    <input asp-for="TransactionId" class="form-control" />
                    <span asp-validation-for="TransactionId" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SwiftReceiptPath" class="form-label"></label>
                    <input asp-for="SwiftReceiptPath" class="form-control" />
                    <span asp-validation-for="SwiftReceiptPath" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<CollectionRecordStatus>()"></select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            </div>

            <hr />
            <div class="d-flex justify-content-between">
                <div>
                    <a asp-controller="CollectionChannels" asp-action="Details" asp-route-id="@Model.ChannelId" class="btn btn-secondary">@Localizer["Cancel"]</a>
                </div>
                <div>
                    <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                        <i class="align-middle" data-lucide="trash-2"></i> @Localizer["Delete"]
                    </button>
                    <button type="submit" class="btn btn-primary">@Localizer["Save Changes"]</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Delete" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">@Localizer["Delete Collection Record"]</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <p>@Localizer["Are you sure you want to delete this collection record? This action cannot be undone."]</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                    <button type="submit" class="btn btn-danger">@Localizer["Confirm Delete"]</button>
                </div>
            </form>
        </div>
    </div>
</div>
