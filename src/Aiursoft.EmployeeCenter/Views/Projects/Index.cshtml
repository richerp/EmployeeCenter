@model Aiursoft.EmployeeCenter.Models.ProjectsViewModels.IndexViewModel
@{
    ViewData["Title"] = "Projects";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">@Localizer["GitLab Projects"]</h1>
    </div>

    @if (Model.ProjectsByTags.Any())
    {
        @foreach (var tagGroup in Model.ProjectsByTags)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="align-middle" data-lucide="tag"></i>
                        <span class="badge bg-primary">@tagGroup.Tag</span>
                        <span class="text-muted ms-2">(@tagGroup.Projects.Count @Localizer["projects"])</span>
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        @foreach (var project in tagGroup.Projects)
                        {
                            <div class="col-12 col-md-6 col-lg-4 mb-3">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <h5 class="card-title">
                                            <a href="@project.WebUrl" target="_blank" class="text-decoration-none">
                                                @project.Name
                                            </a>
                                        </h5>
                                        @if (!string.IsNullOrWhiteSpace(project.Description))
                                        {
                                            <p class="card-text text-muted">@project.Description</p>
                                        }
                                        <div class="d-flex gap-2">
                                            @if (project.Topics.Any())
                                            {
                                                @foreach (var topic in project.Topics.Take(3))
                                                {
                                                    <span class="badge bg-secondary">@topic</span>
                                                }
                                                @if (project.Topics.Count > 3)
                                                {
                                                    <span class="badge bg-light text-dark">+@(project.Topics.Count - 3)</span>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <div class="card-footer bg-transparent">
                                        <small class="text-muted">
                                            <a href="@project.HttpUrlToRepo" target="_blank" class="me-3">
                                                <i class="align-middle" data-lucide="link"></i> HTTPS
                                            </a>
                                            <a href="@project.SshUrlToRepo" target="_blank">
                                                <i class="align-middle" data-lucide="terminal"></i> SSH
                                            </a>
                                        </small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="align-middle" data-lucide="info"></i>
            @Localizer["No projects found."]
        </div>
    }
</div>
