@model Aiursoft.EmployeeCenter.Models.ServersViewModels.CreateServerViewModel

<h1 class="h3 mb-3">@Localizer["Add New Server"]</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Basic Information"]</h5>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Hostname" class="form-label"></label>
                            <input asp-for="Hostname" class="form-control" placeholder="e.g. web-server-01" />
                            <span asp-validation-for="Hostname" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ServerIp" class="form-label"></label>
                            <input asp-for="ServerIp" class="form-control" placeholder="e.g. 192.168.1.10" />
                            <span asp-validation-for="ServerIp" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="LocationId" class="form-label"></label>
                            <div class="input-group">
                                <select asp-for="LocationId" class="form-select" asp-items="@(new SelectList(Model.AllLocations, "Id", "Name"))">
                                    <option value="">-- @Localizer["Select Location"] --</option>
                                </select>
                                <button type="button" class="btn btn-outline-secondary reload-dropdown" 
                                        data-url="@Url.Action("GetLocations")" 
                                        data-target="LocationId" 
                                        data-placeholder="@Localizer["Select Location"]"
                                        title="@Localizer["Reload"]">
                                    <i class="align-middle" data-lucide="rotate-cw"></i>
                                </button>
                            </div>
                            <span asp-validation-for="LocationId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ProviderId" class="form-label"></label>
                            <div class="input-group">
                                <select asp-for="ProviderId" class="form-select" asp-items="@(new SelectList(Model.AllProviders, "Id", "Name"))">
                                    <option value="">-- @Localizer["Select Provider"] --</option>
                                </select>
                                <button type="button" class="btn btn-outline-secondary reload-dropdown" 
                                        data-url="@Url.Action("GetProviders")" 
                                        data-target="ProviderId" 
                                        data-placeholder="@Localizer["Select Provider"]"
                                        title="@Localizer["Reload"]">
                                    <i class="align-middle" data-lucide="rotate-cw"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ProviderId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="OwnerId" class="form-label"></label>
                        <div class="input-group">
                            <select asp-for="OwnerId" class="form-select" asp-items="@(new SelectList(Model.AllOwners, "Id", "DisplayName"))">
                                <option value="">-- @Localizer["Select Owner"] --</option>
                            </select>
                            <button type="button" class="btn btn-outline-secondary reload-dropdown" 
                                    data-url="@Url.Action("GetUsers")" 
                                    data-target="OwnerId" 
                                    data-placeholder="@Localizer["Select Owner"]"
                                    data-name-key="displayName"
                                    title="@Localizer["Reload"]">
                                <i class="align-middle" data-lucide="rotate-cw"></i>
                            </button>
                        </div>
                        <span asp-validation-for="OwnerId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DetailLink" class="form-label"></label>
                        <input asp-for="DetailLink" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="DetailLink" class="text-danger"></span>
                    </div>

                </div>
                <div class="card-footer text-end">
                    <button type="submit" class="btn btn-primary">@Localizer["Save Server"]</button>
                    <a asp-action="Index" class="btn btn-light">@Localizer["Cancel"]</a>
                </div>
            </div>
        </form>
    </div>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function reloadDropdown(url, targetId, placeholder, groupByKey = null, nameKey = "name", idKey = "id") {
                const target = document.getElementById(targetId);
                const originalValue = target.value;
                const reloadBtn = document.querySelector(`.reload-dropdown[data-target="${targetId}"]`);
                const icon = reloadBtn?.querySelector('i, svg');
                
                if (icon) {
                    icon.classList.add('spin');
                }

                fetch(url)
                    .then(response => response.json())
                    .then(data => {
                        target.innerHTML = '';
                        const defaultOption = document.createElement('option');
                        defaultOption.value = '';
                        defaultOption.textContent = '-- ' + placeholder + ' --';
                        target.appendChild(defaultOption);

                        if (groupByKey) {
                            const groups = {};
                            data.forEach(item => {
                                const groupName = item[groupByKey] || 'Other';
                                if (!groups[groupName]) {
                                    groups[groupName] = document.createElement('optgroup');
                                    groups[groupName].label = groupName;
                                    target.appendChild(groups[groupName]);
                                }
                                const option = document.createElement('option');
                                option.value = item[idKey];
                                option.textContent = item[nameKey];
                                if (item[idKey].toString() === originalValue.toString()) {
                                    option.selected = true;
                                }
                                groups[groupName].appendChild(option);
                            });
                        } else {
                            data.forEach(item => {
                                const option = document.createElement('option');
                                option.value = item[idKey];
                                option.textContent = item[nameKey];
                                if (item[idKey].toString() === originalValue.toString()) {
                                    option.selected = true;
                                }
                                target.appendChild(option);
                            });
                        }
                    })
                    .catch(error => console.error('Error reloading dropdown:', error))
                    .finally(() => {
                        if (icon) {
                            icon.classList.remove('spin');
                        }
                    });
            }

            document.querySelectorAll('.reload-dropdown').forEach(btn => {
                btn.addEventListener('click', function () {
                    const url = this.dataset.url;
                    const target = this.dataset.target;
                    const placeholder = this.dataset.placeholder;
                    const groupByKey = this.dataset.groupBy;
                    const nameKey = this.dataset.nameKey || 'name';
                    const idKey = this.dataset.idKey || 'id';
                    reloadDropdown(url, target, placeholder, groupByKey, nameKey, idKey);
                });
            });
        });
    </script>
}
