@model Aiursoft.EmployeeCenter.Models.IntangibleAssetsViewModels.DetailsViewModel
@using Aiursoft.EmployeeCenter.Entities

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Intangible Asset Details"]</h3>
    </div>
    <div class="col-auto ms-auto mt-n1">
        <a asp-action="Edit" asp-route-id="@Model.Asset.Id" class="btn btn-primary">
            <i class="align-middle" data-lucide="edit"></i> @Localizer["Edit"]
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">@Localizer["General Information"]</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">@Localizer["Name"]</dt>
                    <dd class="col-sm-8">@Model.Asset.Name</dd>

                    <dt class="col-sm-4">@Localizer["Type"]</dt>
                    <dd class="col-sm-8">@Model.Asset.Type</dd>

                    <dt class="col-sm-4">@Localizer["Status"]</dt>
                    <dd class="col-sm-8">@Model.Asset.Status</dd>

                    <dt class="col-sm-4">@Localizer["Supplier"]</dt>
                    <dd class="col-sm-8">@(Model.Asset.Supplier ?? "-")</dd>
                    
                    <dt class="col-sm-4">@Localizer["Description"]</dt>
                    <dd class="col-sm-8">@(Model.Asset.Description ?? "-")</dd>
                </dl>
            </div>
        </div>

        <div class="card">
             <div class="card-header">
                <h5 class="card-title">@Localizer["Access Information"]</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">@Localizer["Management URL"]</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(Model.Asset.ManagementUrl))
                        {
                            <a href="@Model.Asset.ManagementUrl" target="_blank">@Model.Asset.ManagementUrl</a>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </dd>

                    <dt class="col-sm-4">@Localizer["Account"]</dt>
                    <dd class="col-sm-8">@(Model.Asset.Account ?? "-")</dd>

                    <dt class="col-sm-4">@Localizer["Password"]</dt>
                    <dd class="col-sm-8">
                        @if(!string.IsNullOrEmpty(Model.Asset.Password))
                        {
                            <span class="text-muted">@Localizer["Hidden"]</span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">@Localizer["Filing & Registration"]</h5>
            </div>
            <div class="card-body">
                 <dl class="row">
                    <dt class="col-sm-4">@Localizer["Filing Number"]</dt>
                    <dd class="col-sm-8">@(Model.Asset.FilingNumber ?? "-")</dd>

                    <dt class="col-sm-4">@Localizer["Filing Subject"]</dt>
                    <dd class="col-sm-8">@(Model.Asset.FilingSubject ?? "-")</dd>

                    <dt class="col-sm-4">@Localizer["Query Method"]</dt>
                    <dd class="col-sm-8">@(Model.Asset.FilingQueryMethod ?? "-")</dd>

                    <dt class="col-sm-4">@Localizer["Registration Date"]</dt>
                    <dd class="col-sm-8">@(Model.Asset.RegistrationDate?.ToString("yyyy-MM-dd") ?? "-")</dd>

                    <dt class="col-sm-4">@Localizer["Expiration Date"]</dt>
                    <dd class="col-sm-8">@(Model.Asset.ExpirationDate?.ToString("yyyy-MM-dd") ?? "-")</dd>
                </dl>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="card-title">@Localizer["Financial & Assignment"]</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">@Localizer["Purchase Price"]</dt>
                    <dd class="col-sm-8">@(Model.Asset.PurchasePrice?.ToString("C") ?? "-")</dd>

                    <dt class="col-sm-4">@Localizer["Invoice"]</dt>
                    <dd class="col-sm-8">
                         @if (!string.IsNullOrEmpty(Model.Asset.InvoiceFileUrl))
                        {
                            <a href="@Model.Asset.InvoiceFileUrl" target="_blank">@Localizer["View Invoice"]</a>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </dd>

                    <dt class="col-sm-4">@Localizer["Assignee"]</dt>
                    <dd class="col-sm-8">
                        @if (Model.Asset.Assignee != null)
                        {
                            <a asp-controller="Users" asp-action="Details" asp-route-id="@Model.Asset.AssigneeId">@Model.Asset.Assignee.DisplayName</a>
                        }
                        else
                        {
                            <span>@Localizer["Not Assigned"]</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
